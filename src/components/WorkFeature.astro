---
import type { WorkItem } from '../data/types';
import FlagshipVisual from './FlagshipVisual.astro';
type Props = { item: WorkItem; index: number; lead?: boolean };
const { item, index, lead = false } = Astro.props;
const publicType = item.type === 'Research lab' ? 'Public research build' : 'Professional work';
const cta = item.slug === 'claims-intelligence'
  ? 'See the system'
  : item.slug === 'on-prem-rag-ocr'
    ? 'See the review workflow'
    : item.slug === 'healthcare-analytics-platform'
      ? 'See the platform story'
      : 'Open the research build';
---
<article class:list={['work-feature', `accent-${item.accent}`, { lead }]}>
  <div class="feature-index" aria-hidden="true">{String(index).padStart(2, '0')}</div>
  <div class="feature-copy">
    <div class="feature-meta"><span>{publicType}</span><span>{item.domain}</span></div>
    <h3>{item.title}</h3>
    <p>{item.lede}</p>
    <strong class="feature-outcome">{item.outcome}</strong>
    <a class="text-link" href={`/work/${item.slug}/`}>{cta} <span aria-hidden="true">→</span></a>
  </div>
  <FlagshipVisual item={item} compact />
</article>

