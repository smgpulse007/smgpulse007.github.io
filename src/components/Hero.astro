---
import { profile } from '@data/profile';
import ArtifactStackHero from './visual/ArtifactStackHero';
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">{profile.name}</p>
      <h1>Production AI systems for healthcare, insurance, and agentic workflows.</h1>
      <h2>{profile.role}</h2>
      <p class="lede">{profile.positioning}</p>
      <p class="hero-proof">FHIR/HL7 | LangGraph | RAG/OCR | FastAPI | Azure | MLflow | XGBoost | LLMOps</p>
      <div class="button-row">
        <a class="button" href="/projects/">View Case Studies</a>
        <a class="button secondary" href="/systems/">Explore Systems</a>
        <a class="button secondary" href={profile.github}>GitHub</a>
      </div>
    </div>
    <ArtifactStackHero client:load />
  </div>
</section>

<style>
  .hero {
    padding: 52px 0 28px;
    display: grid;
    align-items: center;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(560px, 1.12fr);
    gap: 56px;
    align-items: center;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--cyan);
    font-size: 0.8rem;
    font-weight: 950;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.55rem, 4.15vw, 4.7rem);
    line-height: 1;
    letter-spacing: 0;
  }

  h2 {
    margin: 18px 0 0;
    color: var(--cyan);
    font-size: clamp(1.25rem, 2.8vw, 2rem);
    line-height: 1.15;
    letter-spacing: 0;
  }

  .lede {
    max-width: 720px;
    margin: 22px 0 0;
    color: #d8e6f7;
    font-size: clamp(1.06rem, 2vw, 1.28rem);
  }

  .hero-proof {
    max-width: 760px;
    margin: 18px 0 30px;
    border: 1px solid rgba(241, 189, 92, 0.26);
    border-radius: 999px;
    padding: 9px 14px;
    background: rgba(241, 189, 92, 0.075);
    color: #fff0bf;
    font-size: 0.98rem;
    font-weight: 850;
    line-height: 1.45;
  }

  @media (max-width: 1080px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 38px;
    }

    h1 {
      font-size: 2.28rem;
      line-height: 1.04;
    }

    .hero-proof {
      border-radius: 18px;
      font-size: 0.9rem;
    }

    .button-row {
      display: grid;
      grid-template-columns: 1fr;
      overflow: visible;
      padding-bottom: 0;
    }

    .button-row .button {
      width: 100%;
      min-height: 42px;
      padding: 9px 14px;
    }
  }
</style>
