---
import Layout from '@components/Layout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import SectionHeader from '@components/SectionHeader.astro';
import { profile } from '@data/profile';
import { caseStudyProjects } from '@data/projects';
---

<Layout
  title={`Case Studies | ${profile.name}`}
  description="Substantive applied AI, healthcare AI, document AI, LLM steering, quant research, and sports forecasting case studies by Shailesh Dudala."
  canonicalPath="/projects/"
>
  <section class="section intro">
    <div class="container">
      <p class="section-kicker">Case studies</p>
      <h1>Public-safe engineering case studies with rendered architecture, workflow controls, validation, and responsible-use notes.</h1>
      <p class="section-copy">The broader project library lives under Systems; this page focuses on projects with enough public detail to discuss architecture and tradeoffs.</p>
    </div>
  </section>
  <section class="section cards">
    <div class="container card-grid">
      {caseStudyProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
  <section class="section compact">
    <div class="container">
      <SectionHeader kicker="Safety" title="Public-safe by design." copy={profile.privacyNote} />
    </div>
  </section>
</Layout>

<style>
  .intro {
    padding-bottom: 24px;
  }

  h1 {
    max-width: 1040px;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.65rem, 5.8vw, 5rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .cards {
    padding-top: 20px;
  }
</style>
