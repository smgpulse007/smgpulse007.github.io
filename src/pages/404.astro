---
import Layout from '@components/Layout.astro';
---

<Layout
  title="Page Not Found | Shailesh Dudala"
  description="The requested portfolio page was not found."
  canonicalPath="/404/"
>
  <section class="section">
    <div class="container not-found panel">
      <p class="section-kicker">404</p>
      <h1>Page not found</h1>
      <p>The page may have moved. Return to the portfolio homepage or browse the case studies.</p>
      <div class="button-row">
        <a class="button" href="/">Home</a>
        <a class="button secondary" href="/projects/">Case Studies</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    border-radius: 8px;
    padding: 36px;
  }

  h1 {
    margin: 0 0 12px;
    font-size: clamp(2.6rem, 6vw, 4.6rem);
  }

  p {
    color: var(--muted);
  }
</style>

