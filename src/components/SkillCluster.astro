---
type Props = {
  title: string;
  skills: string[];
};

const { title, skills } = Astro.props;
---

<article class="skill-cluster glass-card">
  <h3>{title}</h3>
  <div class="skill-list">
    {skills.map((skill) => <span class="chip">{skill}</span>)}
  </div>
</article>

<style>
  .skill-cluster {
    min-height: 100%;
    padding: 20px;
  }

  h3 {
    margin: 0 0 16px;
    color: var(--text-strong);
    font-size: 1.05rem;
    line-height: 1.18;
    letter-spacing: 0;
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
</style>
