---
import Badge from '@components/ui/Badge.astro';
import { getProject, type Project } from '@data/projects';

const lead = getProject('hospital-readmission-fhir-ml-api') as Project;
const medium = ['llm-steering', 'agentic-alpha-engine'].map((slug) => getProject(slug)).filter(Boolean) as Project[];
const small = ['nfl-sports-forecasting', 'hl7-ai-challenge', 'freshtrack-ai-module', 'local-document-ai-extraction'].map((slug) => getProject(slug)).filter(Boolean) as Project[];
const readmissionSnippet = `{
  "risk_band": "high",
  "top_features": [
    "prior_admissions_180d",
    "comorbidity_count",
    "abnormal_labs"
  ],
  "review_surface": "care_management"
}`;
---

<div class="featured-work">
  <article class="flagship-card">
    <div class="flagship-copy">
      <p class="section-kicker">Flagship case study</p>
      <h3>{lead.title}</h3>
      <p>{lead.summary}</p>
      <div class="work-stack">
        {lead.techStack.slice(0, 6).map((item) => <Badge tone="cyan">{item}</Badge>)}
      </div>
      <div class="button-row">
        <a class="button" href={lead.caseStudyUrl}>Case Study</a>
        <a class="button secondary" href={lead.githubUrl}>GitHub</a>
      </div>
    </div>
    <a class="flagship-visual image-frame" href={lead.caseStudyUrl} aria-label={`Open ${lead.title} case study`}>
      <pre aria-hidden="true"><code>{readmissionSnippet}</code></pre>
    </a>
  </article>

  <div class="medium-grid">
    {medium.map((project, index) => (
      <a class:list={['medium-card', index === 0 ? 'violet' : 'amber']} href={project.caseStudyUrl}>
        <img src={index === 0 ? '/assets/case-studies/llm-steering/screenshots/workbench-ui-overview.gif' : '/assets/case-studies/alphaquant/screenshots/ui-screenshot.png'} alt="" loading="lazy" />
        <div>
          <span>{project.domain}</span>
          <h3>{project.title}</h3>
          <p>{project.problem}</p>
        </div>
      </a>
    ))}
  </div>

  <div class="small-grid">
    {small.map((project) => (
      <article class="small-card">
        <img src={project.image} alt="" loading="lazy" />
        <div>
          <span>{project.domain}</span>
          <h4>{project.shortTitle}</h4>
          <p>{project.problem}</p>
          <div class="small-actions">
            <a href={project.caseStudyUrl}>Case Study</a>
            <a href={project.githubUrl}>GitHub</a>
          </div>
        </div>
      </article>
    ))}
  </div>
</div>

<style>
  .featured-work {
    display: grid;
    gap: 16px;
  }

  .flagship-card {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(360px, 0.7fr);
    gap: 20px;
    border: 1px solid rgba(191, 203, 220, 0.14);
    border-radius: 28px;
    padding: 22px;
    background:
      radial-gradient(circle at 15% 8%, rgba(88, 220, 230, 0.16), transparent 17rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.024)),
      rgba(7, 13, 23, 0.92);
    box-shadow: 0 28px 90px rgba(0, 0, 0, 0.32);
  }

  .flagship-copy {
    display: grid;
    align-content: center;
    gap: 18px;
  }

  .flagship-copy h3,
  .medium-card h3 {
    margin: 0;
    color: var(--text-strong);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .flagship-copy h3 {
    font-size: clamp(2rem, 4vw, 4rem);
  }

  .flagship-copy p,
  .medium-card p,
  .small-card p {
    margin: 0;
    color: var(--muted);
  }

  .work-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .flagship-visual {
    position: relative;
    min-height: 360px;
    padding: 16px;
    background:
      linear-gradient(rgba(255, 255, 255, 0.028) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.028) 1px, transparent 1px),
      #050a12;
    background-size: 28px 28px, 28px 28px, auto;
  }

  .flagship-visual img {
    display: none;
  }

  .flagship-visual pre {
    overflow: auto;
    height: 100%;
    margin: 0;
    border: 1px solid rgba(88, 220, 230, 0.2);
    border-radius: 18px;
    padding: 22px;
    background: rgba(2, 6, 12, 0.72);
    color: #dffbff;
    font-size: clamp(0.86rem, 1vw, 1rem);
    line-height: 1.7;
  }

  .medium-grid,
  .small-grid {
    display: grid;
    gap: 16px;
  }

  .medium-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .small-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .medium-card,
  .small-card {
    overflow: hidden;
    border: 1px solid rgba(191, 203, 220, 0.14);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.02)),
      rgba(7, 13, 23, 0.9);
    transition:
      transform var(--duration) ease,
      border-color var(--duration) ease,
      box-shadow var(--duration) ease;
  }

  .medium-card:hover,
  .small-card:hover {
    transform: translateY(-3px);
    border-color: rgba(88, 220, 230, 0.34);
    box-shadow: 0 22px 64px rgba(0, 0, 0, 0.3);
  }

  .medium-card {
    display: grid;
    grid-template-columns: minmax(180px, 0.48fr) minmax(0, 1fr);
  }

  .medium-card img,
  .small-card img {
    width: 100%;
    height: 100%;
    min-height: 210px;
    object-fit: cover;
    background: #05070c;
  }

  .medium-card div,
  .small-card div {
    display: grid;
    gap: 10px;
    padding: 18px;
  }

  .medium-card span,
  .small-card span {
    color: var(--amber);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .medium-card.violet span {
    color: var(--violet);
  }

  .medium-card h3 {
    font-size: clamp(1.35rem, 2vw, 2.1rem);
  }

  .small-card h4 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1rem;
    line-height: 1.15;
    letter-spacing: 0;
  }

  .small-actions {
    display: flex !important;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0 !important;
  }

  .small-actions a {
    color: #dffbff;
    font-size: 0.82rem;
    font-weight: 900;
  }

  @media (max-width: 1080px) {
    .flagship-card,
    .medium-card {
      grid-template-columns: 1fr;
    }

    .small-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .medium-grid,
    .small-grid {
      grid-template-columns: 1fr;
    }

    .flagship-visual {
      min-height: 260px;
    }
  }
</style>
