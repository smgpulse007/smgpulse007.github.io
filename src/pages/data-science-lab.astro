---
import Layout from '@components/Layout.astro';
import ProjectFilterTabs from '@components/ProjectFilterTabs.astro';
import SectionHeader from '@components/SectionHeader.astro';
import { profile } from '@data/profile';
import { getProject, type Project } from '@data/projects';

const labSlugs = [
  'chatwithwiki-azureml',
  'azure-los-prediction',
  'rag-implementation-hedis-ssd',
  'hedis-dashboard',
  'medication-recommendation',
  'hnsc-viz',
  'gpu-analysis',
  'ml-templates',
];

const labProjects = labSlugs.map((slug) => getProject(slug)).filter((project): project is Project => Boolean(project));
---

<Layout
  title={`Data Science Lab | ${profile.name}`}
  description="Research archive and data science foundations across healthcare analytics, RAG, visualization, forecasting, GPU planning, and scientific ML by Shailesh Dudala."
  canonicalPath="/data-science-lab/"
>
  <section class="section intro">
    <div class="container">
      <p class="section-kicker">Research Archive & Data Science Foundations</p>
      <h1>Selected experiments that show the foundation behind current AI systems work.</h1>
      <p class="section-copy">Healthcare analytics, HEDIS/RAG concepts, visualization notes, GPU planning, forecasting, and reusable ML patterns are curated here as background evidence for the flagship systems.</p>
    </div>
  </section>

  <section class="section compact">
    <div class="container lab-note glass-card">
      <p class="section-kicker">Curation principle</p>
      <h2>Foundation work is useful when it is labeled clearly.</h2>
      <p>These repos show analytical breadth, research habits, and early workflow patterns. Medication recommendation content remains explicitly non-clinical.</p>
    </div>
  </section>

  <section class="section cards">
    <div class="container">
      <ProjectFilterTabs projects={labProjects} compact />
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader kicker="Safety" title="No clinical or sensitive-data claims are made for lab projects." copy="The lab is public-safe and deliberately conservative: toy data, concept repos, local demos, research notes, and archive/foundation material only." />
    </div>
  </section>
</Layout>

<style>
  .intro {
    padding-bottom: 24px;
  }

  h1 {
    max-width: 1060px;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.55rem, 5.6vw, 5rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .cards {
    padding-top: 20px;
  }

  .lab-note {
    padding: 26px;
  }

  .lab-note h2 {
    margin: 0 0 10px;
    color: var(--text-strong);
    font-size: clamp(1.5rem, 2.4vw, 2.2rem);
    letter-spacing: 0;
  }

  .lab-note p:last-child {
    margin: 0;
    color: var(--muted);
  }
</style>
