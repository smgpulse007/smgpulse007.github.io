---
import Badge from '@components/ui/Badge.astro';

const domains = [
  {
    title: 'Healthcare & Interoperability AI',
    description: 'FHIR R4, HL7 event flows, readmission risk, LOS, ED utilization, care gaps, quality programs, and reviewable risk outputs.',
    tone: 'cyan',
    stack: ['FHIR R4', 'HL7 ADT/ORU/MDM', 'HEDIS', 'FastAPI'],
    example: 'Hospital Readmission FHIR ML API',
    href: '/projects/hospital-readmission-fhir-ml-api/',
  },
  {
    title: 'Claims & Document Automation',
    description: 'OCR, structured extraction, validation gates, confidence scoring, exception routing, and document-to-data workflows.',
    tone: 'emerald',
    stack: ['OCR', 'Tesseract', 'LangChain', 'Review queues'],
    example: 'FreshTrack AI + sanitized claims patterns',
    href: '/projects/freshtrack-ai-module/',
  },
  {
    title: 'Agentic AI & LLMOps',
    description: 'LangGraph-style orchestration, tool calling, local LLMs, activation steering, evaluation gates, and observability surfaces.',
    tone: 'violet',
    stack: ['LangGraph', 'Ollama', 'PyTorch', 'React'],
    example: 'LLM Steering Lab',
    href: '/projects/llm-steering/',
  },
  {
    title: 'Quant, Forecasting & Backtesting',
    description: 'AlphaQuant, sports forecasting, Elo, XGBoost, calibration, model comparison, Brier score, and historical backtesting.',
    tone: 'amber',
    stack: ['XGBoost', 'Elo', 'Brier score', 'Backtests'],
    example: 'AlphaQuant + Sports Forecasting Lab',
    href: '/quant-forecasting/',
  },
  {
    title: 'MLOps & Infrastructure',
    description: 'Dockerized APIs, CI checks, MLflow-style delivery, Azure patterns, Kubernetes readiness, health checks, and deployment discipline.',
    tone: 'slate',
    stack: ['Docker', 'CI/CD', 'Azure', 'MLflow'],
    example: 'Systems Library',
    href: '/systems/',
  },
  {
    title: 'Research & Data Science Foundations',
    description: 'Biomedical informatics, visualization, GPU planning, scientific ML, time-series analysis, and earlier experimental systems.',
    tone: 'rose',
    stack: ['scikit-learn', 'Visualization', 'GPU planning', 'RAG'],
    example: 'Research Archive',
    href: '/research-archive/',
  },
];
---

<div class="domain-grid">
  {domains.map((domain, index) => (
    <a class:list={['domain-card', domain.tone, index === 0 && 'lead']} href={domain.href}>
      <span class="domain-index">{String(index + 1).padStart(2, '0')}</span>
      <h3>{domain.title}</h3>
      <p>{domain.description}</p>
      <div class="domain-stack" aria-label={`${domain.title} stack`}>
        {domain.stack.map((item) => <Badge tone={domain.tone as any}>{item}</Badge>)}
      </div>
      <strong>{domain.example}</strong>
    </a>
  ))}
</div>

<style>
  .domain-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .domain-card {
    --domain-accent: var(--cyan);
    display: grid;
    gap: 16px;
    min-height: 312px;
    border: 1px solid rgba(191, 203, 220, 0.14);
    border-top: 4px solid var(--domain-accent);
    border-radius: 24px;
    padding: 22px;
    background:
      radial-gradient(circle at 20% 0%, color-mix(in srgb, var(--domain-accent) 18%, transparent), transparent 12rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.02)),
      rgba(7, 13, 23, 0.9);
    box-shadow: 0 18px 54px rgba(0, 0, 0, 0.22);
    transition:
      transform var(--duration) ease,
      border-color var(--duration) ease,
      box-shadow var(--duration) ease;
  }

  .domain-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--domain-accent) 58%, white 8%);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.34);
  }

  .domain-card.lead {
    grid-column: span 2;
  }

  .cyan { --domain-accent: var(--cyan); }
  .emerald { --domain-accent: var(--green); }
  .violet { --domain-accent: var(--violet); }
  .amber { --domain-accent: var(--amber); }
  .rose { --domain-accent: var(--rose); }
  .slate { --domain-accent: #cbd5e1; }

  .domain-index {
    color: var(--domain-accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.82rem;
    font-weight: 950;
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.22rem, 2vw, 1.82rem);
    line-height: 1.1;
    letter-spacing: 0;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.52;
  }

  .domain-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: auto;
  }

  strong {
    color: #f8fbff;
    font-size: 0.92rem;
  }

  @media (max-width: 980px) {
    .domain-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .domain-card.lead {
      grid-column: auto;
    }
  }

  @media (max-width: 680px) {
    .domain-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
