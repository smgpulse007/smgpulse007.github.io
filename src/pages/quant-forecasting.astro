---
import Layout from '@components/Layout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import SectionHeader from '@components/SectionHeader.astro';
import ArchitectureDiagram from '@components/ArchitectureDiagram.astro';
import { profile } from '@data/profile';
import { getProject, type Project } from '@data/projects';

const projects = ['agentic-alpha-engine', 'nfl-sports-forecasting']
  .map((slug) => getProject(slug))
  .filter((project): project is Project => Boolean(project));
---

<Layout
  title={`Quant & Forecasting | ${profile.name}`}
  description="Quant research, agentic market intelligence, sports forecasting, model calibration, and backtesting systems by Shailesh Dudala."
  canonicalPath="/quant-forecasting/"
>
  <section class="section intro">
    <div class="container">
      <p class="section-kicker">Quant & forecasting</p>
      <h1>Agentic market intelligence and sports forecasting as engineering systems, not hype or advice.</h1>
      <p class="section-copy">This section shows analytical breadth: public-signal ingestion, forecasting baselines, calibration, ensembles, backtesting, and verification-heavy reporting.</p>
    </div>
  </section>

  <section class="section compact">
    <div class="container disclaimer glass-card">
      <p class="section-kicker">Responsible-use boundary</p>
      <h2>Research and engineering demos only.</h2>
      <p>These projects are not investment advice, not financial advice, not gambling advice, not betting advice, and not live trading or wagering products.</p>
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader kicker="Flagship analytical systems" title="Agentic market research and historical sports forecasting." />
      <div class="two-column-grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="section compact">
    <div class="container diagram-stack">
      <SectionHeader kicker="Architecture" title="Forecasting and research pipelines need inspectable flow." copy="AlphaQuant emphasizes agent orchestration and evidence verification. The NFL lab emphasizes baselines, model comparison, calibration, and historical backtesting." />
      <ArchitectureDiagram variant="alphaquant" />
      <ArchitectureDiagram variant="nfl" />
    </div>
  </section>
</Layout>

<style>
  .intro {
    padding-bottom: 24px;
  }

  h1 {
    max-width: 1040px;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.7rem, 5.8vw, 5.1rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .disclaimer {
    padding: 26px;
  }

  .disclaimer h2 {
    margin: 0 0 10px;
    color: var(--text-strong);
    font-size: clamp(1.5rem, 2.4vw, 2.2rem);
    letter-spacing: 0;
  }

  .disclaimer p:last-child {
    margin: 0;
    color: var(--muted);
  }

  .diagram-stack {
    display: grid;
    gap: 18px;
  }
</style>
