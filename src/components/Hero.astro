---
import { profile } from '@data/profile';
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Applied AI systems portfolio</p>
      <h1>{profile.name}</h1>
      <h2>{profile.role}</h2>
      <p class="lede">I build production AI systems for healthcare, insurance, claims automation, document intelligence, FHIR/HL7 interoperability, and LLMOps.</p>
      <div class="button-row">
        <a class="button" href="/projects/">View Case Studies</a>
        <a class="button secondary" href={profile.github}>GitHub</a>
        <a class="button secondary" href={profile.linkedin}>LinkedIn</a>
        <span class="button secondary disabled" aria-disabled="true">Resume available on request</span>
      </div>
    </div>
    <div class="hero-art panel">
      <img src="/assets/hero-system-map.svg" alt="Applied AI system map showing interoperability, agentic AI, document AI, ML services, and LLMOps." />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 86px 0 56px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1fr);
    gap: 34px;
    align-items: center;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--cyan);
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.4rem, 8vw, 6.8rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  h2 {
    margin: 18px 0 0;
    color: var(--cyan);
    font-size: clamp(1.35rem, 3vw, 2rem);
  }

  .lede {
    max-width: 680px;
    margin: 22px 0 30px;
    color: #d5e4f6;
    font-size: clamp(1.1rem, 2.2vw, 1.32rem);
  }

  .hero-art {
    border-radius: 8px;
    padding: 14px;
    box-shadow: 0 24px 90px rgba(54, 215, 232, 0.14);
  }

  .hero-art img {
    display: block;
    width: 100%;
    border-radius: 8px;
  }

  @media (max-width: 920px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-art {
      order: -1;
    }
  }
  @media (max-width: 640px) {
    .hero {
      padding-top: 50px;
    }
  }
</style>

