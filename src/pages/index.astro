---
import Layout from '@components/Layout.astro';
import Hero from '@components/Hero.astro';
import MetricCard from '@components/MetricCard.astro';
import ProjectCard from '@components/ProjectCard.astro';
import SkillCluster from '@components/SkillCluster.astro';
import { profile, impactMetrics } from '@data/profile';
import { projects } from '@data/projects';
import { recognition } from '@data/recognition';
import { skillClusters } from '@data/skills';
---

<Layout
  title="Shailesh Dudala | Applied AI & Agentic AI Engineer"
  description={profile.description}
  canonicalPath="/"
>
  <Hero />

  <section class="section">
    <div class="container">
      <p class="section-kicker">Selected outcomes</p>
      <h2 class="section-title">Production AI delivery, translated into public-safe proof.</h2>
      <p class="section-copy">{profile.impactNote}</p>
      <div class="metrics-grid">
        {impactMetrics.map((metric) => <MetricCard value={metric.value} label={metric.label} />)}
      </div>
    </div>
  </section>

  <section class="section featured">
    <div class="container">
      <p class="section-kicker">Featured systems</p>
      <h2 class="section-title">Six public demos that map to serious applied AI systems.</h2>
      <p class="section-copy">Each case study links to a sanitized repository and focuses on system shape: APIs, data contracts, orchestration, validation, and public-safe implementation boundaries.</p>
      <div class="card-grid project-grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-kicker">Capability map</p>
      <h2 class="section-title">Applied AI stack across workflow, model, document, and healthcare systems.</h2>
      <div class="skill-grid">
        {skillClusters.map((cluster) => <SkillCluster title={cluster.title} skills={cluster.skills} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-kicker">Recognition</p>
      <h2 class="section-title">Healthcare AI challenge recognition.</h2>
      <div class="recognition-grid">
        {recognition.map((item) => (
          <article class="recognition-card panel">
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 14px;
    margin-top: 28px;
  }

  .project-grid,
  .skill-grid,
  .recognition-grid {
    margin-top: 30px;
  }

  .skill-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 16px;
  }

  .recognition-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .recognition-card {
    border-radius: 8px;
    padding: 24px;
  }

  .recognition-card h3 {
    margin: 0 0 10px;
    font-size: 1.1rem;
  }

  .recognition-card p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 1080px) {
    .metrics-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .skill-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .metrics-grid,
    .skill-grid,
    .recognition-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

