---
type Props = {
  title: string;
  skills: string[];
};

const { title, skills } = Astro.props;
---

<article class="skill panel">
  <h3>{title}</h3>
  <ul>
    {skills.map((skill) => <li>{skill}</li>)}
  </ul>
</article>

<style>
  .skill {
    border-radius: 8px;
    padding: 22px;
  }

  h3 {
    margin: 0 0 14px;
    color: var(--cyan);
    font-size: 1.08rem;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    padding: 5px 9px;
    border: 1px solid rgba(159, 180, 209, 0.18);
    border-radius: 8px;
    color: var(--muted);
    background: rgba(159, 180, 209, 0.06);
    font-size: 0.9rem;
    font-weight: 700;
  }
</style>

