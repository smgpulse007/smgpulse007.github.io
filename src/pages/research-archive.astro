---
import Layout from '@components/Layout.astro';
import ProjectFilterTabs from '@components/ProjectFilterTabs.astro';
import SectionHeader from '@components/SectionHeader.astro';
import { profile } from '@data/profile';
import { getProject, type Project } from '@data/projects';

const archiveSlugs = [
  'chatwithwiki-azureml',
  'azure-los-prediction',
  'rag-implementation-hedis-ssd',
  'hedis-dashboard',
  'medication-recommendation',
  'hnsc-viz',
  'gpu-analysis',
  'ml-templates',
];

const archiveProjects = archiveSlugs.map((slug) => getProject(slug)).filter((project): project is Project => Boolean(project));
---

<Layout
  title={`Research Archive | ${profile.name}`}
  description="Research Archive and Data Science Foundations across healthcare analytics, RAG, forecasting, visualization, GPU planning, and scientific ML by Shailesh Dudala."
  canonicalPath="/research-archive/"
>
  <section class="section intro">
    <div class="container">
      <p class="section-kicker">Research Archive & Data Science Foundations</p>
      <h1>Earlier experiments in healthcare analytics, biomedical informatics, forecasting, visualization, GPU planning, and scientific ML.</h1>
      <p class="section-copy">These projects show the technical foundation behind the current systems portfolio: modeling notebooks, RAG concepts, visualization work, infrastructure planning, and reusable ML patterns.</p>
    </div>
  </section>

  <section class="section compact">
    <div class="container shelf-grid">
      <article>
        <span>Healthcare analytics foundations</span>
        <p>LOS prediction, HEDIS RAG concepts, care-quality analysis, and healthcare dashboard foundations.</p>
      </article>
      <article>
        <span>Biomedical / scientific ML</span>
        <p>Activation visualization, dimensionality reduction, model inspection, and scientific analysis patterns.</p>
      </article>
      <article>
        <span>Infrastructure & performance</span>
        <p>GPU planning, local inference thinking, reusable ML templates, and system-readiness notes.</p>
      </article>
    </div>
  </section>

  <section class="section cards">
    <div class="container">
      <ProjectFilterTabs projects={archiveProjects} compact />
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader kicker="Safety" title="Archive projects stay conservative." copy="Medication recommendation remains non-clinical. Forecasting projects remain historical analytics. Public examples do not include PHI, PII, secrets, or employer-confidential data." />
    </div>
  </section>
</Layout>

<style>
  .intro {
    padding-bottom: 24px;
  }

  h1 {
    max-width: 1060px;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.55rem, 5.6vw, 5rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .cards {
    padding-top: 20px;
  }

  .shelf-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .shelf-grid article {
    border: 1px solid rgba(191, 203, 220, 0.14);
    border-radius: 22px;
    padding: 20px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.02)),
      rgba(7, 13, 23, 0.9);
  }

  .shelf-grid span {
    color: var(--cyan);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .shelf-grid p {
    margin: 10px 0 0;
    color: var(--muted);
  }

  @media (max-width: 860px) {
    .shelf-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
