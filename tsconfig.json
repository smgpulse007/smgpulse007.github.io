{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@data/*": ["src/data/*"],
      "@lib/*": ["src/lib/*"]
    }
  },
  "exclude": ["dist", "node_modules", "playwright-report", "test-results", "docs/screenshots", "qa-screenshots"]
}

