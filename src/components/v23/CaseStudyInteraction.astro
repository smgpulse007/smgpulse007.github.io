---
import ClaimsRun from './ClaimsRun.astro';
type Props = { slug: string };
const { slug } = Astro.props;
const predictiveRows = [
  { model:'Logistic baseline', auroc:'.74', brier:'.168', calibration:'Stable', note:'Interpretable release reference' },
  { model:'Boosted trees', auroc:'.79', brier:'.151', calibration:'Corrected', note:'Challenger after calibration' },
  { model:'Complex ensemble', auroc:'.80', brier:'.165', calibration:'Variable', note:'Rejected: complexity did not earn release cost' },
];
const programs = [
  { name:'Risk stratification', copy:'Shared feature and delivery services support a program-specific cohort, calibrated risk band, threshold policy, and reviewer capacity.' },
  { name:'Readmission', copy:'The index event, exclusion rules, 30-day horizon, transition context, and post-discharge action path remain specific to readmission.' },
  { name:'ED utilization', copy:'Near-term utilization patterns, visit cadence, access signals, and outreach capacity change both the feature window and operating threshold.' },
  { name:'Quality gaps', copy:'Measure eligibility, evidence freshness, closure rules, and chart-review queues matter more than a generic risk rank.' },
  { name:'Care management', copy:'Program enrollment, caseload capacity, contactability, and feedback capture shape how a score becomes a work queue.' },
  { name:'SDoH', copy:'Proxy risk, missingness, resource availability, and consent require explicit review before a social-risk signal can inform action.' },
  { name:'Utilization review', copy:'Length-of-stay and service patterns arrive with different timing, review authority, and escalation costs than care-management models.' },
  { name:'Provider analytics', copy:'Provider identity, attribution, network context, and data-quality rules sit on the shared platform but require their own validation contract.' },
  { name:'Performance reporting', copy:'Metric definitions, refresh cadence, lineage, and owner sign-off become the program-specific layer over reusable data delivery.' },
];
---
{slug === 'claims-intelligence' && <ClaimsRun />}
{slug === 'predictive-healthcare-ml' && <section class="case-instrument predictive-instrument" aria-labelledby="predictive-instrument-title"><header><span>INTERACTIVE MODEL REVIEW / SYNTHETIC</span><h2 id="predictive-instrument-title">A model earns release one decision at a time.</h2><p>Switch the evaluation lens. The leading row changes when probability quality, slice stability, and operating cost matter alongside discrimination.</p></header><div class="predictive-controls" role="group" aria-label="Evaluation lens">{['Discrimination','Calibration','Operational fit'].map((label,index)=><button type="button" class:list={{active:index===0}} aria-pressed={index===0?'true':'false'} data-predictive-lens={index}>{label}</button>)}</div><div class="model-comparison" data-model-comparison>{predictiveRows.map((row,index)=><article class:list={{selected:index===2}} data-model-row={index}><div><span>{String(index+1).padStart(2,'0')}</span><strong>{row.model}</strong></div><dl><div><dt>AUROC</dt><dd>{row.auroc}</dd></div><div><dt>Brier</dt><dd>{row.brier}</dd></div><div><dt>Calibration</dt><dd>{row.calibration}</dd></div></dl><p>{row.note}</p></article>)}</div><aside data-predictive-note><strong>Discrimination lens:</strong> the complex ensemble has the highest illustrative AUROC, but that alone does not earn release.</aside><noscript><div class="case-static-decisions"><p><strong>Calibration:</strong> boosted trees lead after correction because their Brier score and probability quality are strongest.</p><p><strong>Operational fit:</strong> the logistic baseline remains viable when freshness, latency, and reviewer explanation dominate.</p></div></noscript></section>}
{slug === 'healthcare-analytics-platform' && <section class="case-instrument platform-instrument" aria-labelledby="platform-instrument-title"><header><span>PROGRAM MAP / SANITIZED</span><h2 id="platform-instrument-title">Nine programs. One reusable delivery spine.</h2><p>Select a program context to see what stayed shared and what remained specific.</p></header><div class="platform-map"><div class="program-ring">{programs.map((program,index)=><button type="button" style={`--i:${index}`} class:list={{active:index===0}} aria-pressed={index===0?'true':'false'} data-program={program.name} data-program-copy={program.copy}>{String(index+1).padStart(2,'0')}<span>{program.name}</span></button>)}<div><span>SHARED SPINE</span><strong>Data → models → delivery → workflow</strong></div></div><aside><span>SELECTED CONTEXT</span><h3 data-program-title>{programs[0].name}</h3><p data-program-copy>{programs[0].copy}</p><ol><li>Versioned program contract</li><li>Reusable feature + delivery services</li><li>Program-specific action and feedback</li></ol></aside></div><noscript><div class="case-static-decisions"><h3>All program-specific layers</h3>{programs.map((program)=><p><strong>{program.name}:</strong> {program.copy}</p>)}</div></noscript></section>}
{slug === 'on-prem-rag-ocr' && <section class="case-instrument document-instrument" aria-labelledby="document-instrument-title"><header><span>EVIDENCE INSPECTOR / SYNTHETIC</span><h2 id="document-instrument-title">The answer is only as useful as its source trail.</h2><p>Inspect a page, the extracted field, and the reason a local workflow routes the case to review.</p></header><div class="document-review"><nav aria-label="Synthetic document pages">{[['04','Policy','Apr 01'],['05','Form','Apr 11'],['09','Note','supporting']].map(([page,type,value],index)=><button type="button" class:list={{active:index===0}} data-doc-page={page} data-doc-type={type} data-doc-value={value}><span>PAGE {page}</span><strong>{type}</strong><small>{value}</small></button>)}</nav><div class="document-page"><span data-page-label>PAGE 04 / POLICY</span><div class="redacted-lines" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i></div><mark data-page-value>effective date: Apr 01</mark></div><aside><span>LOCAL REVIEW STATE</span><h3>Evidence conflict</h3><dl><div><dt>Page 04</dt><dd>Apr 01</dd></div><div><dt>Page 05</dt><dd>Apr 11</dd></div><div><dt>Route</dt><dd>Reviewer confirmation</dd></div></dl><p>Source pages remain inside the controlled environment. The reviewer sees citations and the failed rule—not an unsupported confidence badge.</p></aside></div></section>}
<script>
  document.querySelectorAll<HTMLElement>('[data-predictive-lens]').forEach((button)=>button.addEventListener('click',()=>{const root=button.closest('.predictive-instrument');if(!root)return;const lens=Number(button.dataset.predictiveLens)||0;root.querySelectorAll<HTMLElement>('[data-predictive-lens]').forEach((item)=>{const active=item===button;item.classList.toggle('active',active);item.setAttribute('aria-pressed',String(active))});const selectedRows=[2,1,0];root.querySelectorAll<HTMLElement>('[data-model-row]').forEach((row)=>row.classList.toggle('selected',Number(row.dataset.modelRow)===selectedRows[lens]));const notes=['<strong>Discrimination lens:</strong> the complex ensemble has the highest illustrative AUROC, but that alone does not earn release.','<strong>Calibration lens:</strong> the corrected boosted-tree challenger produces the strongest illustrative probability quality.','<strong>Operational-fit lens:</strong> the interpretable logistic baseline remains viable when freshness, latency, and reviewer explanation dominate.'];const note=root.querySelector('[data-predictive-note]');if(note)note.innerHTML=notes[lens]}));
  document.querySelectorAll<HTMLElement>('[data-program]').forEach((button)=>button.addEventListener('click',()=>{const root=button.closest('.platform-instrument');if(!root)return;root.querySelectorAll<HTMLElement>('[data-program]').forEach((item)=>{const active=item===button;item.classList.toggle('active',active);item.setAttribute('aria-pressed',String(active))});const title=root.querySelector('[data-program-title]');const copy=root.querySelector('[data-program-copy]');if(title)title.textContent=button.dataset.program??'';if(copy)copy.textContent=button.dataset.programCopy??''}));
  document.querySelectorAll<HTMLElement>('[data-doc-page]').forEach((button)=>button.addEventListener('click',()=>{const root=button.closest('.document-instrument');if(!root)return;root.querySelectorAll('[data-doc-page]').forEach((item)=>item.classList.toggle('active',item===button));const label=root.querySelector('[data-page-label]');const value=root.querySelector('[data-page-value]');if(label)label.textContent=`PAGE ${button.dataset.docPage} / ${button.dataset.docType}`;if(value)value.textContent=`extracted field: ${button.dataset.docValue}`}));
</script>
