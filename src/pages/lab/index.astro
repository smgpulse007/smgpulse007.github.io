---
import Layout from '../../components/Layout.astro';
import ProjectWorkbench from '../../components/v23/ProjectWorkbench.astro';
import { featuredProjects, exploreProjects, archiveProjects, projectInventory } from '../../data/v23';
---
<Layout title="Project Lab — Shailesh Dudala" description="A proof-attached Project Lab across representation engineering, agent systems, predictive healthcare, interoperability, document intelligence, forecasting, scientific computing, and MLOps." canonicalPath="/lab/">
  <span id="healthcare" class="legacy-fragment-anchor" aria-hidden="true"></span><span id="documents" class="legacy-fragment-anchor" aria-hidden="true"></span><span id="agentic" class="legacy-fragment-anchor" aria-hidden="true"></span><span id="forecasting" class="legacy-fragment-anchor" aria-hidden="true"></span>
  <section class="v23-page-hero lab-v23-hero"><div class="shell"><p class="v23-kicker">PROJECT LAB / {projectInventory.length - 2} AUTHORED REPOSITORIES AUDITED</p><div><h1>A field of systems, not a shelf of cards.</h1><p>Open-source systems, experiments, and technical foundations organized by problem, artifact maturity, repository health, public proof, and explicit limitation.</p><p class="lab-featured-line"><strong>Featured proof:</strong> LLM Steering · Meta Harness · Readmission FHIR ML API · HL7 AI Challenge</p></div></div></section>
  <section class="v23-section lab-workbench-section"><div class="shell v23-section-heading"><div><p class="v23-kicker">Featured / interactive inspector</p><h2>Repository existence is not proof maturity.</h2></div><p>Search the inspected inventory, select a system, and keep its status and boundary in view.</p></div><div class="shell"><ProjectWorkbench /></div></section>
  <section class="v23-section featured-dossiers"><div class="shell v23-section-heading"><div><p class="v23-kicker">Featured / {featuredProjects.length}</p><h2>Systems with the strongest public evidence.</h2></div><p>Featured does not mean production. It means the source, artifacts, and current limits make the engineering inspectable.</p></div><div class="shell dossier-stack">{featuredProjects.map((project,index)=><article><div class="dossier-number"><span>{String(index+1).padStart(2,'0')}</span><small>{project.category}</small></div><div><h3>{project.title}</h3><p>{project.proof}</p></div><dl><div><dt>Status</dt><dd>{project.status}</dd></div><div><dt>Limit</dt><dd>{project.limitation}</dd></div></dl><div class="dossier-links">{project.href&&<a href={project.href}>Open system ↗</a>}<a href={project.repository}>Repository ↗</a></div></article>)}</div></section>
  <section class="v23-section explore-ledger-section"><div class="shell v23-section-heading"><div><p class="v23-kicker">Explore / {exploreProjects.length}</p><h2>Substantive side paths and earlier systems.</h2></div><p>Red CI, absent tests, reference-only status, and historical framing remain visible.</p></div><div class="shell project-ledger">{exploreProjects.map((project,index)=><article><span>{String(index+1).padStart(2,'0')}</span><div><small>{project.category}</small><h3>{project.title}</h3></div><strong>{project.status}</strong><p>{project.proof}</p><p class="limit">{project.limitation}</p><a href={project.href??project.repository}>Inspect ↗</a></article>)}</div></section>
  <section class="v23-section archive-ledger-section"><div class="shell"><details><summary><span>Archive / {archiveProjects.length}</span><strong>Historical learning, small utilities, and repositories not promoted as current systems</strong><i>Open inventory +</i></summary><div class="archive-ledger">{archiveProjects.map((project)=><article><div><small>{project.category}</small><h3>{project.title}</h3></div><p>{project.proof}</p><span>{project.status}</span><a href={project.repository}>Repository ↗</a></article>)}</div></details></div></section>
  <section class="v23-inline-contact"><div class="shell"><p>Want the professional systems first?</p><a href="/work/">Explore Work →</a><a href="/research/">See the research behind the projects ↗</a></div></section>
</Layout>
