---
import { certifications } from '@data/certifications';
import { impactMetrics } from '@data/profile';

const visibleCredentials = certifications;
---

<section class="section impact-strip" aria-labelledby="impact-strip-title">
  <div class="container">
    <div class="impact-header">
      <p class="section-kicker">Impact + credentials</p>
      <h2 id="impact-strip-title">Outcomes first. Credential badges only when verifiable.</h2>
    </div>

    <div class="impact-grid">
      {impactMetrics.map((metric) => (
        <article class="impact-cell">
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
          <p>{metric.detail}</p>
        </article>
      ))}
    </div>

    <div class="credential-rail" aria-label="Cloud and data credential verification status">
      {visibleCredentials.map((credential) => (
        <article class="credential-cell">
          <span>{credential.provider}</span>
          <h3>{credential.title}</h3>
          {credential.verificationUrl ? (
            <a href={credential.verificationUrl}>
              {credential.badgeImage ? <img src={credential.badgeImage} alt={`${credential.provider} verified badge`} loading="lazy" /> : 'Verify credential'}
            </a>
          ) : (
            <p>{credential.note}</p>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .impact-strip {
    padding: 46px 0 58px;
    border-block: 1px solid rgba(191, 203, 220, 0.12);
    background:
      linear-gradient(90deg, rgba(241, 189, 92, 0.06), transparent 30%, rgba(141, 232, 180, 0.055)),
      rgba(5, 9, 15, 0.76);
  }

  .impact-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 18px;
  }

  .impact-header h2 {
    max-width: 840px;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 3vw, 3rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .impact-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    overflow: hidden;
    border: 1px solid rgba(191, 203, 220, 0.14);
    border-radius: 8px;
    background: rgba(191, 203, 220, 0.1);
  }

  .impact-cell {
    min-height: 142px;
    padding: 18px;
    background: rgba(6, 12, 21, 0.94);
  }

  .impact-cell + .impact-cell {
    border-left: 1px solid rgba(191, 203, 220, 0.1);
  }

  .impact-cell strong {
    display: block;
    color: var(--green);
    font-size: clamp(1.9rem, 3.2vw, 3rem);
    line-height: 1;
  }

  .impact-cell span {
    display: block;
    margin-top: 10px;
    color: var(--text-strong);
    font-weight: 900;
    line-height: 1.18;
  }

  .impact-cell p {
    margin: 8px 0 0;
    color: var(--muted-2);
    font-size: 0.82rem;
    line-height: 1.35;
  }

  .credential-rail {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 14px;
  }

  .credential-cell {
    min-height: 128px;
    border: 1px solid rgba(191, 203, 220, 0.14);
    border-radius: 8px;
    padding: 16px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.02)),
      rgba(7, 13, 23, 0.9);
  }

  .credential-cell span {
    color: var(--amber);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .credential-cell h3 {
    margin: 8px 0 10px;
    color: var(--text-strong);
    font-size: 1rem;
    line-height: 1.2;
  }

  .credential-cell p,
  .credential-cell a {
    margin: 0;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.42;
  }

  .credential-cell a {
    color: var(--cyan);
    font-weight: 900;
  }

  @media (max-width: 1040px) {
    .impact-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .impact-cell:nth-child(4) {
      border-left: 0;
    }

    .credential-rail {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .impact-header {
      display: block;
    }

    .impact-grid,
    .credential-rail {
      grid-template-columns: 1fr;
    }

    .impact-cell + .impact-cell {
      border-left: 0;
      border-top: 1px solid rgba(191, 203, 220, 0.1);
    }
  }
</style>
