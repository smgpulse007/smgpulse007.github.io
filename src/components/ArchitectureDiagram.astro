---
import type { DiagramVariant } from '@data/projects';

type DiagramStep = {
  title: string;
  detail: string;
};

type Diagram = {
  title: string;
  description: string;
  steps: DiagramStep[];
};

type Props = {
  variant: DiagramVariant;
};

const { variant } = Astro.props;

const diagrams: Record<DiagramVariant, Diagram> = {
  readmission: {
    title: 'Hospital Readmission FHIR ML API architecture',
    description: 'Synthetic FHIR resources flow through validation, parsing, feature extraction, scoring, explanations, and FastAPI responses.',
    steps: [
      { title: 'Synthetic FHIR Bundle', detail: 'Patient, encounter, condition, medication, observation, procedure' },
      { title: 'Schema Validation', detail: 'Typed request contracts and required-resource checks' },
      { title: 'FHIR Parser', detail: 'Normalize resources into model-ready records' },
      { title: 'Feature Builder', detail: 'Utilization, comorbidity, labs, discharge context' },
      { title: 'Risk Scorer', detail: 'Probability, band, and contribution signals' },
      { title: 'Explanation API', detail: 'Top factors and model-card metadata' },
      { title: 'FastAPI Response', detail: 'Single and batch scoring outputs' },
    ],
  },
  hl7: {
    title: 'HL7 AI Challenge Platform architecture',
    description: 'HL7-style events become FHIR resources, quality signals, risk intelligence, CDS-style actions, and dashboard/audit outputs.',
    steps: [
      { title: 'HL7-style Events', detail: 'ADT, ORU, MDM-inspired sample flows' },
      { title: 'Event Gateway', detail: 'RabbitMQ-backed routing' },
      { title: 'FHIR Mapper', detail: 'R4-aligned resource transformation' },
      { title: 'Quality Intelligence', detail: 'Care gaps, HEDIS, measure context' },
      { title: 'Risk Services', detail: 'Prediction and prioritization signals' },
      { title: 'CDS / SMART Layer', detail: 'Workflow-aware action surface' },
      { title: 'Dashboard + Audit', detail: 'Review and traceability' },
    ],
  },
  'llm-steering': {
    title: 'LLM Steering Lab architecture',
    description: 'Prompt pairs create steering vectors that are applied through model hooks and inspected in a FastAPI/React workbench.',
    steps: [
      { title: 'Prompt Pairs', detail: 'Contrastive behavior examples' },
      { title: 'Vector Extraction', detail: 'ActAdd-style representation delta' },
      { title: 'Model Registry', detail: 'Supported runtimes and limits' },
      { title: 'Activation Hook', detail: 'Apply steering during inference' },
      { title: 'Baseline Compare', detail: 'Steered vs unsteered outputs' },
      { title: 'FastAPI Workbench', detail: 'Runs, controls, and evidence' },
      { title: 'React UI', detail: 'Reviewable comparisons' },
    ],
  },
  'document-ai': {
    title: 'Local Document AI Extraction architecture',
    description: 'PDFs are parsed locally, chunked, prompted through Ollama/LangChain, and reviewed in a Streamlit interface.',
    steps: [
      { title: 'PDF Upload', detail: 'Sample or private local file input' },
      { title: 'PDFPlumber Parse', detail: 'Text extraction without remote upload' },
      { title: 'Chunking', detail: 'Windowed context for prompts' },
      { title: 'Prompt Assembly', detail: 'Analyst criteria plus context' },
      { title: 'Ollama / LangChain', detail: 'Local model invocation' },
      { title: 'Structured Result', detail: 'Extraction answer and rationale' },
      { title: 'Streamlit Review', detail: 'Human-readable surface' },
    ],
  },
  alphaquant: {
    title: 'Agentic Alpha / AlphaQuant architecture',
    description: 'Public signals flow through ingestion, storage, agent planning, tool calls, verification, and structured report surfaces.',
    steps: [
      { title: 'Public Signals', detail: 'Market, macro, news, filings-style inputs' },
      { title: 'Ingestion Adapters', detail: 'Explicit data boundaries' },
      { title: 'Storage Fabric', detail: 'Postgres, Redis, Qdrant, MinIO, search' },
      { title: 'Agent Planner', detail: 'Task graph, tool routing, state' },
      { title: 'Tool Calls', detail: 'Retrieval, scoring, synthesis support' },
      { title: 'Verification', detail: 'Rules, citations, consistency checks' },
      { title: 'Report / API / UI', detail: 'Structured research artifacts' },
    ],
  },
  nfl: {
    title: 'NFL Sports Forecasting architecture',
    description: 'Historical games and features feed Elo, ML models, ensembles, calibration, and historical backtesting outputs.',
    steps: [
      { title: 'Historical Games', detail: 'Seasons, teams, scores' },
      { title: 'Feature Builder', detail: 'Team stats and schedule context' },
      { title: 'Elo Baseline', detail: 'Interpretable reference model' },
      { title: 'ML Models', detail: 'XGBoost and logistic regression' },
      { title: 'Ensemble', detail: 'Probability blending' },
      { title: 'Calibration', detail: 'Brier score and probability quality' },
      { title: 'Backtesting', detail: 'Historical decisions and results' },
    ],
  },
  freshtrack: {
    title: 'FreshTrack AI Module architecture',
    description: 'Receipt-like images move through OCR, parsing, optional LLM cleanup, confidence scoring, and structured JSON output.',
    steps: [
      { title: 'Image Upload', detail: 'Receipt or document image input' },
      { title: 'Preprocessing', detail: 'Image cleanup for OCR' },
      { title: 'Tesseract OCR', detail: 'Raw text extraction baseline' },
      { title: 'Text Cleanup', detail: 'Remove totals and noise' },
      { title: 'Optional LLM Parser', detail: 'False-positive reduction' },
      { title: 'Confidence Scoring', detail: 'Item-level quality signals' },
      { title: 'JSON API', detail: 'Frontend/database ready contract' },
    ],
  },
  chatwithwiki: {
    title: 'ChatWithWiki AzureML RAG architecture',
    description: 'Public wiki-style content moves through retrieval, prompt-flow orchestration, Jinja templates, answer generation, and review.',
    steps: [
      { title: 'Public Content', detail: 'Wiki-style source material' },
      { title: 'Retriever', detail: 'Relevant passage selection' },
      { title: 'Prompt Flow', detail: 'Cloud workflow nodes' },
      { title: 'Jinja Template', detail: 'Prompt construction' },
      { title: 'LLM Call', detail: 'Grounded answer draft' },
      { title: 'Answer Artifact', detail: 'Inspectable response' },
      { title: 'Review Notes', detail: 'Grounding assessment' },
    ],
  },
};

const diagram = diagrams[variant];
const nodeWidth = 136;
const nodeHeight = 92;
const gap = 20;
const startX = 30;
const nodeY = 74;
const viewWidth = startX * 2 + diagram.steps.length * nodeWidth + (diagram.steps.length - 1) * gap;
const viewHeight = 240;
const markerId = `arrow-${variant}`;
const titleId = `${variant}-diagram-title`;
const descId = `${variant}-diagram-desc`;
---

<figure class="architecture glass-card">
  <figcaption>
    <span>Rendered architecture</span>
    <strong>{diagram.title}</strong>
  </figcaption>
  <div class="diagram-scroll">
    <svg viewBox={`0 0 ${viewWidth} ${viewHeight}`} role="img" aria-labelledby={`${titleId} ${descId}`} preserveAspectRatio="xMidYMid meet">
      <title id={titleId}>{diagram.title}</title>
      <desc id={descId}>{diagram.description}</desc>
      <defs>
        <linearGradient id={`line-${variant}`} x1="0%" x2="100%" y1="0%" y2="0%">
          <stop offset="0%" stop-color="#58dce6" />
          <stop offset="52%" stop-color="#86efac" />
          <stop offset="100%" stop-color="#f7c86a" />
        </linearGradient>
        <marker id={markerId} markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
          <path d="M0,0 L8,4 L0,8 Z" fill="#58dce6" />
        </marker>
      </defs>
      <rect x="10" y="18" width={viewWidth - 20} height={viewHeight - 36} rx="8" fill="rgba(255,255,255,0.025)" stroke="rgba(180,202,232,0.12)" />
      {diagram.steps.slice(0, -1).map((_, index) => {
        const x1 = startX + index * (nodeWidth + gap) + nodeWidth;
        const x2 = x1 + gap - 8;
        const y = nodeY + nodeHeight / 2;
        return <line x1={x1} y1={y} x2={x2} y2={y} stroke={`url(#line-${variant})`} stroke-width="2" marker-end={`url(#${markerId})`} />;
      })}
      {diagram.steps.map((step, index) => {
        const x = startX + index * (nodeWidth + gap);
        return (
          <foreignObject x={x} y={nodeY} width={nodeWidth} height={nodeHeight}>
            <div xmlns="http://www.w3.org/1999/xhtml" class="diagram-node">
              <strong>{step.title}</strong>
              <span>{step.detail}</span>
            </div>
          </foreignObject>
        );
      })}
    </svg>
  </div>
  <p>{diagram.description}</p>
</figure>

<style>
  .architecture {
    margin: 0;
    padding: 18px;
  }

  figcaption {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 14px;
  }

  figcaption span {
    color: var(--cyan);
    font-size: 0.74rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  figcaption strong {
    color: var(--text-strong);
    font-size: 1rem;
  }

  .diagram-scroll {
    overflow-x: auto;
    padding-bottom: 4px;
  }

  svg {
    display: block;
    min-width: 960px;
    width: 100%;
    height: auto;
  }

  .diagram-node {
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    height: 100%;
    border: 1px solid rgba(88, 220, 230, 0.28);
    border-radius: 8px;
    padding: 10px;
    background: rgba(9, 15, 28, 0.88);
    color: #f7fbff;
    overflow: hidden;
  }

  .diagram-node strong {
    display: block;
    font-size: 0.8rem;
    line-height: 1.15;
  }

  .diagram-node span {
    display: block;
    margin-top: 5px;
    color: #b8c8dc;
    font-size: 0.68rem;
    line-height: 1.18;
  }

  p {
    margin: 12px 0 0;
    color: var(--muted);
  }
</style>
