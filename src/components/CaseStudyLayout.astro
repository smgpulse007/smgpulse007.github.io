---
import Layout from './Layout.astro';
import CaseStudyHero from './CaseStudyHero.astro';
import ArchitectureDiagram from './ArchitectureDiagram.astro';
import MetricCard from './MetricCard.astro';
import SectionHeader from './SectionHeader.astro';
import type { Project } from '@data/projects';
import { profile } from '@data/profile';

type Props = {
  project: Project;
};

const { project } = Astro.props;
const title = `${project.title} | Shailesh Dudala`;
const description = `${project.summary} Case study by Shailesh Dudala.`;
---

<Layout title={title} description={description} canonicalPath={project.caseStudyUrl ?? '/projects/'} image={project.image}>
  <CaseStudyHero project={project} />

  {project.metrics && (
    <section class="section compact">
      <div class="container metrics-grid">
        {project.metrics.map((metric) => <MetricCard value={metric.value} label={metric.label} />)}
      </div>
    </section>
  )}

  <section class="section compact">
    <div class="container case-layout">
      <article class="text-block glass-card">
        <p class="section-kicker">Problem context</p>
        <h2>Why this system exists</h2>
        <p>{project.problem}</p>
      </article>
      <article class="text-block glass-card">
        <p class="section-kicker">System overview</p>
        <h2>What the public demo proves</h2>
        <p>{project.systemOverview}</p>
      </article>
    </div>
  </section>

  {project.architectureVariant && (
    <section class="section compact">
      <div class="container">
        <SectionHeader kicker="Architecture" title="Rendered system flow, not a placeholder." copy={project.architectureSummary} />
        <ArchitectureDiagram variant={project.architectureVariant} />
      </div>
    </section>
  )}

  <section class="section compact">
    <div class="container case-layout">
      <article class="text-block glass-card">
        <h2>Data Flow / Workflow</h2>
        <ul>{project.workflow.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="text-block glass-card">
        <h2>Model or Agent Design</h2>
        <ul>{project.modelDesign.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="text-block glass-card">
        <h2>What I Built</h2>
        <ul>{project.whatIBuilt.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="text-block glass-card">
        <h2>Validation / Reliability / Evaluation</h2>
        <ul>{project.validation.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="text-block glass-card">
        <h2>MLOps / Deployment / Observability</h2>
        <ul>{project.deployment.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="text-block glass-card">
        <h2>Tech Stack</h2>
        <div class="chip-list">{project.techStack.map((item) => <span class="chip">{item}</span>)}</div>
      </article>
      <article class="text-block glass-card">
        <h2>Privacy / Safety / Responsible Use</h2>
        <p>{project.safetyNote}</p>
        <p class="fine-print">{profile.privacyNote}</p>
      </article>
      <article class="text-block glass-card">
        <h2>What This Demonstrates to an Employer</h2>
        <ul>{project.employerValue.map((item) => <li>{item}</li>)}</ul>
      </article>
    </div>
  </section>

  <section class="section compact">
    <div class="container next-panel glass-card">
      <div>
        <p class="section-kicker">Repository and next step</p>
        <h2>{project.title}</h2>
        <p>{project.statusNote}</p>
      </div>
      <div class="button-row">
        <a class="button" href={project.githubUrl}>Open GitHub Repo</a>
        <a class="button secondary" href="/systems/">Explore All Systems</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .metrics-grid,
  .case-layout {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .metrics-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .text-block {
    padding: 24px;
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .next-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: center;
    padding: 26px;
  }

  .next-panel h2 {
    margin: 0 0 8px;
    color: var(--text-strong);
    font-size: clamp(1.4rem, 2.2vw, 2.2rem);
    letter-spacing: 0;
  }

  .next-panel p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 840px) {
    .metrics-grid,
    .case-layout,
    .next-panel {
      grid-template-columns: 1fr;
    }
  }
</style>
