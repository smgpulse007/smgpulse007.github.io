---
import { profile } from '@data/profile';
import AppliedSystemsConsole from './visual/AppliedSystemsConsole';
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">{profile.name}</p>
      <h1>Applied AI Systems Console</h1>
      <h2>{profile.role}</h2>
      <p class="lede">{profile.positioning}</p>
      <p class="hero-proof">Regulated healthcare AI, claims automation, document intelligence, agentic workflows, forecasting, and MLOps shown through public-safe system artifacts.</p>
      <div class="button-row">
        <a class="button" href="/projects/">View Case Studies</a>
        <a class="button secondary" href="/systems/">Explore Systems</a>
        <a class="button secondary" href={profile.github}>GitHub</a>
      </div>
    </div>
    <AppliedSystemsConsole client:load />
  </div>
</section>

<style>
  .hero {
    padding: 58px 0 36px;
    display: grid;
    align-items: center;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(480px, 1.22fr);
    gap: 38px;
    align-items: center;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--cyan);
    font-size: 0.8rem;
    font-weight: 950;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(3rem, 6.8vw, 6.4rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  h2 {
    margin: 18px 0 0;
    color: var(--cyan);
    font-size: clamp(1.25rem, 2.8vw, 2rem);
    line-height: 1.15;
    letter-spacing: 0;
  }

  .lede {
    max-width: 720px;
    margin: 22px 0 0;
    color: #d8e6f7;
    font-size: clamp(1.06rem, 2vw, 1.28rem);
  }

  .hero-proof {
    max-width: 760px;
    margin: 18px 0 30px;
    border-left: 3px solid var(--amber);
    padding-left: 14px;
    color: #e9f8ff;
    font-size: 0.98rem;
    font-weight: 850;
  }

  @media (max-width: 940px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 52px;
    }
  }
</style>
