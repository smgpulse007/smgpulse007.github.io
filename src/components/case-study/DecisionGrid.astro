---
type Props = {
  title: string;
  items: Array<{ title: string; body: string } | string>;
};

const { title, items } = Astro.props;
---

<section class="decision-section">
  <h2>{title}</h2>
  <div class="decision-grid">
    {items.map((item, index) => (
      <article class="decision-card glass-card">
        <span>{String(index + 1).padStart(2, '0')}</span>
        {typeof item === 'string' ? (
          <p>{item}</p>
        ) : (
          <>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </>
        )}
      </article>
    ))}
  </div>
</section>

<style>
  .decision-section h2 {
    margin: 0 0 18px;
    color: var(--text-strong);
    font-size: clamp(1.6rem, 2.6vw, 2.55rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .decision-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .decision-card {
    padding: 20px;
  }

  span {
    color: var(--amber);
    font-size: 0.76rem;
    font-weight: 950;
    letter-spacing: 0.1em;
  }

  h3 {
    margin: 12px 0 8px;
    color: var(--text-strong);
    font-size: 1.08rem;
    line-height: 1.2;
    letter-spacing: 0;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .decision-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
