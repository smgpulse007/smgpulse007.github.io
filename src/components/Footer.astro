---
import { navigation, profile } from '../data/profile';
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div>
      <a class="footer-brand" href="/">{profile.name}</a>
      <p>{profile.privacyNote}</p>
    </div>
    <nav aria-label="Footer navigation">
      {navigation.slice(0, 5).map((item) => <a href={item.href}>{item.label}</a>)}
      <a href={profile.github}>GitHub ↗</a>
      <a href={profile.linkedin}>LinkedIn ↗</a>
    </nav>
  </div>
  <div class="shell footer-meta">
    <span>Astro · Static by default</span>
    <span>© {new Date().getFullYear()} Shailesh Dudala</span>
  </div>
</footer>
