---
import RepoMaturityBadge from './RepoMaturityBadge.astro';
import type { Project } from '@data/projects';

type Props = {
  project: Project;
  thesis?: string;
};

const { project, thesis } = Astro.props;
---

<section class="case-hero">
  <div class="container case-grid">
    <div class="case-copy">
      <p class="section-kicker">Case study</p>
      <h1>{project.title}</h1>
      <p class="lede">{thesis ?? project.summary}</p>
      <div class="hero-meta">
        <span>{project.domain}</span>
        <RepoMaturityBadge maturity={project.maturity} note={project.statusNote} />
      </div>
      <div class="button-row">
        <a class="button" href={project.githubUrl}>GitHub Repository</a>
        <a class="button secondary" href="/projects/">All Case Studies</a>
      </div>
    </div>
    <div class="case-image glass-card">
      <img src={project.image} alt="" />
    </div>
  </div>
</section>

<style>
  .case-hero {
    padding: 78px 0 42px;
  }

  .case-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(340px, 0.82fr);
    gap: 30px;
    align-items: center;
  }

  h1 {
    max-width: 900px;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.7rem, 6vw, 5.4rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .lede {
    max-width: 820px;
    margin: 22px 0 0;
    color: #d8e6f7;
    font-size: clamp(1.06rem, 1.8vw, 1.28rem);
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin-top: 22px;
    color: var(--muted-2);
    font-size: 0.82rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .button-row {
    margin-top: 28px;
  }

  .case-image {
    padding: 12px;
  }

  img {
    display: block;
    width: 100%;
    border-radius: 8px;
  }

  @media (max-width: 900px) {
    .case-grid {
      grid-template-columns: 1fr;
    }

    .case-image {
      order: -1;
    }
  }
</style>
