---
import Layout from '../components/Layout.astro';
import { profile } from '../data/profile';
import { experienceEras,education,certifications } from '../data/experience';
---
<Layout title="Public résumé — Shailesh Dudala" description="Privacy-cleared public résumé for a Senior Applied AI Engineer spanning predictive ML, context-engineered agents, healthcare products, document intelligence, and execution harnesses." canonicalPath="/resume/">
  <section class="resume-v22-hero"><div class="shell"><div><span>PUBLIC RÉSUMÉ / PRIVACY-CLEARED EDITION</span><h1>Senior Applied AI Engineer</h1><p>Predictive ML · Healthcare platforms · Context engineering · Bounded agents · Harness engineering</p></div><aside><strong>Public edition</strong><p>No phone, precise location, private-client payload, confidential implementation detail, or private application résumé.</p><a class="signal-button" href={profile.resumePath}>Open PDF <span>↗</span></a></aside></div></section>
  <section class="resume-v22-body"><div class="shell"><header><h2>{profile.name}</h2><div><a href={`mailto:${profile.email}`}>{profile.email}</a><a href={profile.github}>GitHub ↗</a><a href={profile.linkedin}>LinkedIn ↗</a></div></header><p class="resume-v22-summary">I build governed intelligent systems that move from uncertain signals to typed, validated workflows with explicit human authority. My work spans predictive healthcare, local document intelligence, context-engineered claims agents, and evidence-gated open-source execution harnesses.</p><div class="resume-v22-columns"><div class="resume-v22-experience"><span>EXPERIENCE</span>{experienceEras.map((era)=><article><div><time>{era.period}</time><h3>{era.organization}</h3><strong>{era.title}</strong></div><div><p>{era.summary}</p><ul>{era.outcomes.map((outcome)=><li>{outcome}</li>)}</ul></div></article>)}</div><aside><section><span>OPEN SOURCE</span><h3>Meta Harness</h3><p>Pre-1.0 evidence-gated execution harness for coding-agent phases, packets, validation, proof, checkpoints, and continuation.</p><h3>LLM Steering</h3><p>Activation-steering workbench with model registry, prompt-pair controls, pre/post hooks, and validated result artifacts.</p></section><section><span>EDUCATION</span><ul>{education.map((entry)=><li>{entry}</li>)}</ul></section><section><span>CREDENTIALS</span><ul>{certifications.map((entry)=><li>{entry}</li>)}</ul></section></aside></div></div></section>
</Layout>
