---
import Layout from '@components/Layout.astro';
import Timeline from '@components/Timeline.astro';
import SectionHeader from '@components/SectionHeader.astro';
import MetricCard from '@components/MetricCard.astro';
import { profile, experienceTimeline, impactMetrics } from '@data/profile';
import { recognition } from '@data/recognition';
---

<Layout
  title={`Experience | ${profile.name}`}
  description="Public-safe applied AI, healthcare ML, insurance AI, claims automation, document intelligence, and MLOps experience story for Shailesh Dudala."
  canonicalPath="/experience/"
>
  <section class="section intro">
    <div class="container">
      <p class="section-kicker">Experience</p>
      <h1>Production applied AI story, described at the right level of public detail.</h1>
      <p class="section-copy">This connects the public portfolio to regulated delivery patterns: healthcare and insurance workflows, document review, quality programs, MLOps, and responsible AI boundaries.</p>
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader kicker="Impact" title="Operational outcomes that inform the public system demos." copy={profile.impactNote} />
      <div class="metrics-grid">
        {impactMetrics.map((metric) => <MetricCard value={metric.value} label={metric.label} detail={metric.detail} />)}
      </div>
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader kicker="Timeline" title="Public-safe narrative across healthcare, insurance, platforms, and research foundations." />
      <Timeline items={experienceTimeline} />
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader kicker="Recognition" title="Healthcare AI recognition that matches the portfolio lead story." />
      <div class="recognition-grid">
        {recognition.map((item) => (
          <article class="recognition-card glass-card">
            <h2>{item.title}</h2>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .intro {
    padding-bottom: 24px;
  }

  h1 {
    max-width: 1000px;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.65rem, 5.8vw, 5rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .metrics-grid,
  .recognition-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .recognition-card {
    padding: 24px;
  }

  .recognition-card h2 {
    margin: 0 0 10px;
    color: var(--text-strong);
    font-size: 1.1rem;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .recognition-card p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 840px) {
    .metrics-grid,
    .recognition-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
