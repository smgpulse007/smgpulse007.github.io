---
import Layout from '../components/Layout.astro';
import { profile } from '../data/profile';
import { experienceEras,education,certifications } from '../data/experience';
---
<Layout title="Public résumé — Shailesh Dudala" description="Privacy-cleared public résumé for a Senior Applied AI / ML Engineer spanning production agentic AI, predictive ML, document intelligence, MLOps, healthcare, and insurance." canonicalPath="/resume/">
  <section class="resume-v22-hero"><div class="shell"><div><span>PUBLIC RÉSUMÉ / PRIVACY-CLEARED EDITION</span><h1>Senior Applied AI / ML Engineer</h1><p>Production Agentic AI · Predictive ML · Document Intelligence · MLOps · Healthcare & Insurance</p></div><aside><strong>Public edition</strong><p>One ATS-readable page. No phone, precise location, private-client payload, confidential implementation detail, or private application résumé.</p><a class="signal-button" href={profile.resumePath}>Open PDF <span>↗</span></a></aside></div></section>
  <section class="resume-v22-body"><div class="shell"><header><h2>{profile.name}</h2><div><a href={`mailto:${profile.email}`}>{profile.email}</a><a href={profile.github}>GitHub ↗</a><a href={profile.linkedin}>LinkedIn ↗</a></div></header><p class="resume-v22-summary">I build complete intelligent systems across the applied-ML arc: scientific data, predictive healthcare, analytics products, private document intelligence, MLOps, and production agentic AI. The public edition keeps outcomes scoped and private implementation details withheld.</p><div class="resume-v22-columns"><div class="resume-v22-experience"><span>EXPERIENCE</span>{experienceEras.map((era)=><article><div><time>{era.period}</time><h3>{era.organization}</h3><strong>{era.title}</strong></div><div><p>{era.summary}</p><ul>{era.outcomes.map((outcome)=><li>{outcome}</li>)}</ul></div></article>)}</div><aside><section><span>SELECTED OPEN SOURCE / SECONDARY</span><h3>LLM Steering</h3><p>Maintained representation-engineering workbench with green CI, UI, checked-in results, and explicit limits.</p><h3>Meta Harness</h3><p>Pre-1.0 execution protocol with schemas, CLI/MCP, proof ledger, docs, and broad checks.</p></section><section><span>EDUCATION</span><ul>{education.map((entry)=><li>{entry}</li>)}</ul></section><section><span>CREDENTIALS</span><ul>{certifications.map((entry)=><li>{entry}</li>)}</ul></section></aside></div></div></section>
</Layout>
