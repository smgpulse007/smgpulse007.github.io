---
import type { Artifact } from '@data/caseStudies';

type Props = {
  artifacts: Artifact[];
};

const { artifacts } = Astro.props;
---

<div class="artifact-gallery">
  {artifacts.map((artifact) => (
    <article class:list={['artifact-card', 'glass-card', artifact.type]}>
      <header>
        <span>{artifact.type}</span>
        <h3>{artifact.title}</h3>
      </header>
      {artifact.src && ['gif', 'image', 'svg'].includes(artifact.type) && (
        <img src={artifact.src} alt={artifact.alt ?? artifact.title} loading="lazy" />
      )}
      {artifact.code && <pre><code>{artifact.code}</code></pre>}
      {artifact.body && <p>{artifact.body}</p>}
    </article>
  ))}
</div>

<style>
  .artifact-gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .artifact-card {
    min-height: 100%;
    padding: 18px;
  }

  .artifact-card.image,
  .artifact-card.gif,
  .artifact-card.svg {
    padding: 14px;
  }

  header {
    margin-bottom: 12px;
  }

  header span {
    color: var(--cyan);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h3 {
    margin: 4px 0 0;
    color: var(--text-strong);
    font-size: 1.05rem;
    line-height: 1.2;
    letter-spacing: 0;
  }

  img {
    display: block;
    width: 100%;
    border: 1px solid rgba(180, 202, 232, 0.16);
    border-radius: 8px;
    background: #05070c;
  }

  pre {
    overflow-x: auto;
    margin: 0;
    border: 1px solid rgba(180, 202, 232, 0.16);
    border-radius: 8px;
    padding: 16px;
    background: rgba(2, 6, 12, 0.72);
    color: #d9f9ff;
    font-size: 0.86rem;
    line-height: 1.55;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 820px) {
    .artifact-gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
