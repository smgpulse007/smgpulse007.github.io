{
  "name": "smgpulse007.github.io",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "node --test scripts/*.test.mjs",
    "test:content": "node scripts/validate-content.mjs",
    "test:links": "node scripts/check-links.mjs dist",
    "test:targets": "node scripts/validate-targets.mjs",
    "test:e2e": "playwright test tests/e2e.spec.ts --project=chromium",
    "test:a11y": "playwright test tests/accessibility.spec.ts --project=chromium",
    "test:visual": "playwright test tests/visual.spec.ts",
    "screenshots": "npm run screenshots:pass1 && npm run screenshots:pass2 && npm run screenshots:pass3",
    "screenshots:pass1": "node scripts/run-visual-qa.mjs pass-1-hierarchy",
    "screenshots:pass2": "node scripts/run-visual-qa.mjs pass-2-polish",
    "screenshots:pass3": "node scripts/run-visual-qa.mjs pass-3-restraint",
    "validate": "npm run check && npm run test && npm run build && npm run test:content && npm run test:links && npm run test:targets && npm run test:a11y && npm run test:e2e"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.6",
    "autoprefixer": "^10.4.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "postcss": "^8.5.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "typescript": "^6.0.3"
  }
}
