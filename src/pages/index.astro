---
import Layout from '@components/Layout.astro';
import Hero from '@components/Hero.astro';
import SectionHeader from '@components/SectionHeader.astro';
import CredentialImpactStrip from '@components/home/CredentialImpactStrip.astro';
import InteractiveDomainExplorer from '@components/home/InteractiveDomainExplorer';
import FeaturedSystemsShowroom from '@components/home/FeaturedSystemsShowroom';
import { profile } from '@data/profile';
---

<Layout title={profile.seoTitle} description={profile.seoDescription} canonicalPath="/">
  <Hero />

  <CredentialImpactStrip />

  <section class="section domain-section">
    <div class="container">
      <SectionHeader
        kicker="Domain modules"
        title="One control surface for regulated AI systems, not a wall of project cards."
        copy="The portfolio is organized around system domains: healthcare standards, claims/document workflows, agentic orchestration, forecasting, and MLOps proof."
      />
      <InteractiveDomainExplorer client:load />
    </div>
  </section>

  <section class="section showroom-section">
    <div class="container">
      <SectionHeader
        kicker="Featured systems showroom"
        title="Lead system, supporting systems, and proof artifacts by domain."
        copy="Each tab keeps the scan path tight: one primary case study, two adjacent systems, and three artifacts that make the implementation concrete."
      />
      <FeaturedSystemsShowroom client:load />
    </div>
  </section>

  <section class="section compact final-cta">
    <div class="container cta-grid">
      <div>
        <p class="section-kicker">Archive routes</p>
        <h2>Long libraries live below the fold of the site, not below the fold of the homepage.</h2>
      </div>
      <div class="cta-actions">
        <a class="button" href="/projects/">Open Case Studies</a>
        <a class="button secondary" href="/systems/">Systems Index</a>
        <a class="button secondary" href="/research-archive/">Research Archive</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .domain-section {
    padding-top: 76px;
  }

  .showroom-section {
    padding-top: 34px;
  }

  .final-cta {
    border-top: 1px solid rgba(191, 203, 220, 0.12);
    background:
      linear-gradient(90deg, rgba(88, 220, 230, 0.055), transparent 42%, rgba(240, 160, 189, 0.045)),
      rgba(5, 9, 15, 0.82);
  }

  .cta-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: center;
  }

  .cta-grid h2 {
    max-width: 900px;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 3.3vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px;
  }

  @media (max-width: 860px) {
    .cta-grid {
      grid-template-columns: 1fr;
    }

    .cta-actions {
      justify-content: flex-start;
    }
  }
</style>
