---
import Layout from '../../components/Layout.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import WorkFeature from '../../components/WorkFeature.astro';
import { workItems } from '../../data/work';
---
<Layout title="Selected Work — Shailesh Dudala" description="Engineering case studies across claims intelligence, local document AI, healthcare analytics products, and model-behavior research." canonicalPath="/work/">
  <section class="page-hero work-hero"><div class="shell work-hero-grid"><div><p class="eyebrow">Selected work</p><h1>Four systems. Four different operating constraints.</h1></div><p>Start with the result and the decision that mattered. Open a study for failure modes, contracts, evaluation, reviewer authority, and source notes.</p></div></section>
  <section class="section"><div class="shell"><SectionIntro eyebrow="Case studies" title="The systems behind the outcomes." body="Three professional stories and one public research build—each with a visual language shaped by the work itself." /><div class="work-stack">{workItems.map((item, index) => <WorkFeature item={item} index={index + 1} lead={index === 0} />)}</div></div></section>
</Layout>
