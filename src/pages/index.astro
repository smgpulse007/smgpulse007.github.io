---
import Layout from '@components/Layout.astro';
import Hero from '@components/Hero.astro';
import MetricCard from '@components/MetricCard.astro';
import ProjectCard from '@components/ProjectCard.astro';
import SkillCluster from '@components/SkillCluster.astro';
import SectionHeader from '@components/SectionHeader.astro';
import CapabilityPillar from '@components/CapabilityPillar.astro';
import ProjectFilterTabs from '@components/ProjectFilterTabs.astro';
import ArchitectureDiagram from '@components/ArchitectureDiagram.astro';
import { profile, impactMetrics, portfolioPillars } from '@data/profile';
import { featuredProjects, projects } from '@data/projects';
import { recognition } from '@data/recognition';
import { skillClusters } from '@data/skills';
---

<Layout title={profile.seoTitle} description={profile.seoDescription} canonicalPath="/">
  <Hero />

  <section class="section">
    <div class="container">
      <SectionHeader
        kicker="Positioning"
        title="Healthcare and insurance AI lead the story; agentic systems, quant research, forecasting, and MLOps show the range."
        copy="The portfolio is organized as public-safe proof of system design: contracts, workflow controls, model boundaries, deployment patterns, diagrams, and responsible-use notes."
      />
      <div class="pillar-grid">
        {portfolioPillars.map((pillar, index) => <CapabilityPillar pillar={pillar} index={index} />)}
      </div>
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader kicker="Selected outcomes" title="Production AI delivery, translated into public-safe evidence." copy={profile.impactNote} />
      <div class="metrics-grid">
        {impactMetrics.map((metric) => <MetricCard value={metric.value} label={metric.label} detail={metric.detail} />)}
      </div>
    </div>
  </section>

  <section class="section featured">
    <div class="container">
      <SectionHeader
        kicker="Featured systems"
        title="Eight systems across healthcare AI, LLMOps, document intelligence, quant research, and sports forecasting."
        copy="The top tier favors projects with real system shape, explicit stack choices, public-safe boundaries, and enough architecture to discuss in an engineering interview."
      />
      <div class="card-grid project-grid">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader
        kicker="System flow"
        title="Architecture thinking is part of the portfolio, not an afterthought."
        copy="Each major case study includes a rendered system diagram. This example shows the agentic market-intelligence stack."
      />
      <ArchitectureDiagram variant="alphaquant" />
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader kicker="Portfolio library" title="Filtered view across the full public project library." copy="Older and weaker repos are tiered honestly as experiments, research notes, or archive/foundation work." />
      <ProjectFilterTabs projects={projects} compact />
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader kicker="Capability map" title="Applied AI stack across healthcare workflows, LLM systems, forecasting, and infrastructure." />
      <div class="skill-grid">
        {skillClusters.map((cluster) => <SkillCluster title={cluster.title} skills={cluster.skills} />)}
      </div>
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader kicker="Recognition" title="Healthcare AI challenge recognition and public proof points." />
      <div class="recognition-grid">
        {recognition.map((item) => (
          <article class="recognition-card glass-card">
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .pillar-grid,
  .skill-grid,
  .recognition-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 14px;
  }

  .project-grid,
  .skill-grid,
  .recognition-grid {
    margin-top: 30px;
  }

  .recognition-card {
    padding: 24px;
  }

  .recognition-card h3 {
    margin: 0 0 10px;
    color: var(--text-strong);
    font-size: 1.1rem;
    letter-spacing: 0;
  }

  .recognition-card p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 1080px) {
    .metrics-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .skill-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 780px) {
    .pillar-grid,
    .metrics-grid,
    .skill-grid,
    .recognition-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
