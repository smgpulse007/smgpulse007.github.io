---
import Layout from './Layout.astro';
import CaseStudyHero from './CaseStudyHero.astro';
import ArchitectureDiagram from './ArchitectureDiagram.astro';
import SectionHeader from './SectionHeader.astro';
import AtAGlance from './case-study/AtAGlance.astro';
import ArtifactGallery from './case-study/ArtifactGallery.astro';
import ProofStrip from './case-study/ProofStrip.astro';
import DecisionGrid from './case-study/DecisionGrid.astro';
import type { Project } from '@data/projects';
import { profile } from '@data/profile';
import { getCaseStudyDetail } from '@data/caseStudies';

type Props = {
  project: Project;
};

const { project } = Astro.props;
const detail = getCaseStudyDetail(project.slug);
const title = `${project.title} | Shailesh Dudala`;
const description = `${detail?.thesis ?? project.summary} Case study by Shailesh Dudala.`;
---

<Layout title={title} description={description} canonicalPath={project.caseStudyUrl ?? '/projects/'} image={project.image}>
  <CaseStudyHero project={project} thesis={detail?.thesis} />

  {detail ? (
    <>
      <section class="section compact">
        <div class="container">
          <AtAGlance detail={detail} />
        </div>
      </section>

      <section class="section compact">
        <div class="container">
          <ProofStrip items={detail.proofStrip} />
        </div>
      </section>

      <section class="section compact">
        <div class="container two-column-grid">
          <article class="text-block proof-panel glass-card">
            <p class="section-kicker">Problem / Stakes</p>
            <h2>Why this system exists.</h2>
            <p>{project.problem}</p>
          </article>
          <article class="text-block proof-panel glass-card">
            <p class="section-kicker">What I Built</p>
            <h2>Public-safe implementation surface.</h2>
            <ul>
              {project.whatIBuilt.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      </section>

      {project.architectureVariant && (
        <section class="section compact">
          <div class="container">
            <SectionHeader
              kicker="Architecture"
              title="A system map shaped for this project."
              copy={project.architectureSummary}
            />
            <ArchitectureDiagram variant={project.architectureVariant} />
          </div>
        </section>
      )}

      <section class="section compact">
        <div class="container">
          <SectionHeader
            kicker="System walkthrough"
            title="How the system moves from input to reviewable output."
          />
          <div class="walkthrough-grid">
            {detail.walkthrough.map((step, index) => (
              <article class="walk-card glass-card">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section compact">
        <div class="container two-column-grid">
          <article class="text-block proof-panel glass-card">
            <p class="section-kicker">Model / Agent / Extraction Design</p>
            <h2>The technical core.</h2>
            <ul>
              {project.modelDesign.map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="text-block proof-panel glass-card">
            <p class="section-kicker">Validation / Reliability / MLOps</p>
            <h2>How the system is made reviewable.</h2>
            <ul>
              {[...project.validation, ...project.deployment].map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      </section>

      <section class="section compact">
        <div class="container">
          <SectionHeader
            kicker="Evidence gallery"
            title="Artifacts from the source repo, not generic portfolio filler."
            copy="Screenshots, GIFs, diagrams, JSON responses, model tables, and proof panels make the implementation concrete."
          />
          <ArtifactGallery artifacts={detail.artifacts} />
        </div>
      </section>

      <section class="section compact">
        <div class="container">
          <DecisionGrid title="Engineering Decisions" items={detail.decisions} />
        </div>
      </section>

      <section class="section compact">
        <div class="container">
          <DecisionGrid title="What This Proves in an Interview" items={detail.interviewProof} />
        </div>
      </section>

      <section class="section compact">
        <div class="container responsible glass-card">
          <p class="section-kicker">Responsible-use boundary</p>
          <h2>{project.safetyNote}</h2>
          <p>{profile.privacyNote}</p>
          <div class="button-row">
            <a class="button" href={project.githubUrl}>Open GitHub Repo</a>
            <a class="button secondary" href="/systems/">Explore All Systems</a>
          </div>
        </div>
      </section>
    </>
  ) : (
    <section class="section compact">
      <div class="container">
        <article class="text-block glass-card fallback">
          <h2>System Overview</h2>
          <p>{project.systemOverview}</p>
        </article>
      </div>
    </section>
  )}
</Layout>

<style>
  .walkthrough-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .walk-card {
    min-height: 100%;
    padding: 20px;
  }

  .walk-card span {
    color: var(--amber);
    font-size: 0.76rem;
    font-weight: 950;
    letter-spacing: 0.1em;
  }

  .walk-card h3 {
    margin: 12px 0 8px;
    color: var(--text-strong);
    font-size: 1.08rem;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .walk-card p,
  .responsible p {
    margin: 0;
    color: var(--muted);
  }

  .responsible {
    padding: 26px;
  }

  .proof-panel {
    padding: 24px;
  }

  .proof-panel h2 {
    font-size: clamp(1.35rem, 2.1vw, 2rem);
  }

  .responsible h2 {
    margin: 0 0 12px;
    color: var(--text-strong);
    font-size: clamp(1.35rem, 2vw, 2rem);
    line-height: 1.15;
    letter-spacing: 0;
  }

  .responsible .button-row {
    margin-top: 22px;
  }

  .fallback {
    padding: 24px;
  }

  @media (max-width: 1040px) {
    .walkthrough-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .walkthrough-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
