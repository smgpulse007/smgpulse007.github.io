---
import Layout from '../../components/Layout.astro';
import { labSystems } from '../../data/observatory';
---
<Layout title="Systems Lab — Shailesh Dudala" description="Open-source systems, experiments, and technical side paths across agent orchestration, healthcare interoperability, document AI, forecasting, quant, and local models." canonicalPath="/lab/">
  <span id="healthcare" class="legacy-fragment-anchor" aria-hidden="true"></span><span id="documents" class="legacy-fragment-anchor" aria-hidden="true"></span><span id="agentic" class="legacy-fragment-anchor" aria-hidden="true"></span><span id="forecasting" class="legacy-fragment-anchor" aria-hidden="true"></span>
  <section class="systems-index-hero lab-index-hero"><div class="shell"><span>SYSTEMS LAB / PUBLIC WORK</span><h1>Curiosity, with proof and limits attached.</h1><p>Open-source systems, experiments, and technical side paths. Different domains test the same principles under different uncertainty structures.</p></div></section>
  <section class="v22-scene lab-field-scene"><div class="shell lab-controls-v22"><label>Search systems<input type="search" data-lab-v22-search placeholder="System, stage, proof, or limit"/></label><div>{['All','Harness','Agent','Product','Context','Prediction'].map((stage)=><button type="button" class:list={{active:stage==='All'}} data-lab-v22-stage={stage}>{stage}</button>)}</div><p aria-live="polite" data-lab-v22-count>{labSystems.length} systems</p></div><div class="shell lab-rail" data-lab-v22-grid>{labSystems.map((system,i)=><article class:list={{flagship:i<2}} data-lab-v22-item data-stage={system.stage} data-search={`${system.title} ${system.problem} ${system.built} ${system.proof} ${system.limits}`.toLowerCase()}><span>{system.stage} / {system.maturity}</span><h2>{system.title}</h2><dl><div><dt>Problem</dt><dd>{system.problem}</dd></div><div><dt>Built</dt><dd>{system.built}</dd></div><div><dt>Proof</dt><dd>{system.proof}</dd></div><div><dt>Status + limit</dt><dd>{system.maturity}. {system.limits}</dd></div></dl><div><a href={system.href}>Open system ↗</a><a href={system.repo}>Repository ↗</a></div></article>)}</div></section>
</Layout>
<script>
  const input=document.querySelector<HTMLInputElement>('[data-lab-v22-search]');const buttons=[...document.querySelectorAll<HTMLButtonElement>('[data-lab-v22-stage]')];const items=[...document.querySelectorAll<HTMLElement>('[data-lab-v22-item]')];const count=document.querySelector<HTMLElement>('[data-lab-v22-count]');let stage='All';const update=()=>{const query=input?.value.trim().toLowerCase()??'';let n=0;items.forEach((item)=>{item.hidden=!((stage==='All'||item.dataset.stage===stage)&&(!query||item.dataset.search?.includes(query)));if(!item.hidden)n++});if(count)count.textContent=`${n} system${n===1?'':'s'}`};buttons.forEach((button)=>button.addEventListener('click',()=>{stage=button.dataset.labV22Stage??'All';buttons.forEach((item)=>item.classList.toggle('active',item===button));update()}));input?.addEventListener('input',update);
</script>
