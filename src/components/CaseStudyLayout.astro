---
import Layout from './Layout.astro';
import CaseStudyHero from './CaseStudyHero.astro';
import ArchitectureDiagram from './ArchitectureDiagram.astro';
import SectionHeader from './SectionHeader.astro';
import AtAGlance from './case-study/AtAGlance.astro';
import ArtifactGallery from './case-study/ArtifactGallery.astro';
import ProofStrip from './case-study/ProofStrip.astro';
import DecisionGrid from './case-study/DecisionGrid.astro';
import type { Project } from '@data/projects';
import { profile } from '@data/profile';
import { getCaseStudyDetail } from '@data/caseStudies';

type Props = {
  project: Project;
};

const { project } = Astro.props;
const detail = getCaseStudyDetail(project.slug);
const title = `${project.title} | Shailesh Dudala`;
const description = `${detail?.thesis ?? project.summary} Case study by Shailesh Dudala.`;
---

<Layout title={title} description={description} canonicalPath={project.caseStudyUrl ?? '/projects/'} image={project.image}>
  <CaseStudyHero project={project} thesis={detail?.thesis} coreEvidence={detail?.proofStrip?.[0]?.value} />

  {detail ? (
    <>
      <section class="section compact">
        <div class="container">
          <AtAGlance detail={detail} />
        </div>
      </section>

      <section class="section compact">
        <div class="container">
          <ProofStrip items={detail.proofStrip} />
        </div>
      </section>

      <section class="section compact">
        <div class="container narrative-grid">
          <article class="narrative-panel">
            <p class="section-kicker">System problem</p>
            <h2>Why this system exists.</h2>
            <p>{project.problem}</p>
          </article>
          <article class="narrative-panel">
            <p class="section-kicker">Implementation surface</p>
            <h2>What was built.</h2>
            <ul>
              {project.whatIBuilt.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      </section>

      {project.architectureVariant && (
        <section class="section compact">
          <div class="container">
            <SectionHeader
              kicker="Architecture"
            title="A system map for the project."
              copy={project.architectureSummary}
            />
            <ArchitectureDiagram variant={project.architectureVariant} />
          </div>
        </section>
      )}

      <section class="section compact">
        <div class="container">
          <SectionHeader
            kicker="How it works"
            title="Input, transformation, model or agent logic, and reviewable output."
          />
          <div class="walkthrough-grid">
            {detail.walkthrough.map((step, index) => (
              <article class="walk-card">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section compact">
        <div class="container">
          <SectionHeader
            kicker="Evidence"
            title="Screenshots, responses, diagrams, tests, and model tables from the source repos."
            copy="Artifacts are included only where the public repo has enough context to show them safely."
          />
          <ArtifactGallery artifacts={detail.artifacts} />
        </div>
      </section>

      <section class="section compact">
        <div class="container">
          <DecisionGrid title="Engineering Decisions" items={detail.decisions} />
        </div>
      </section>

      <section class="section compact">
        <div class="container narrative-grid">
          <article class="narrative-panel">
            <p class="section-kicker">Validation / reliability</p>
            <h2>How the system is made reviewable.</h2>
            <ul>
              {[...project.validation, ...project.deployment].map((item) => <li>{item}</li>)}
            </ul>
          </article>
          <article class="narrative-panel">
            <p class="section-kicker">Limits / responsible use</p>
            <h2>{project.safetyNote}</h2>
            <ul>
              {detail.validationNotes.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      </section>

      <section class="section compact">
        <div class="container repo-cta">
          <div>
            <p class="section-kicker">Repository</p>
            <h2>Open the source repo and inspect the implementation boundary.</h2>
            <p>{profile.privacyNote}</p>
          </div>
          <div class="button-row">
            <a class="button" href={project.githubUrl}>Open GitHub Repo</a>
            <a class="button secondary" href="/projects/">All Case Studies</a>
          </div>
        </div>
      </section>
    </>
  ) : (
    <section class="section compact">
      <div class="container">
        <article class="narrative-panel fallback">
          <h2>System Overview</h2>
          <p>{project.systemOverview}</p>
        </article>
      </div>
    </section>
  )}
</Layout>

<style>
  .narrative-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .narrative-panel,
  .walk-card,
  .repo-cta {
    border: 1px solid rgba(191, 203, 220, 0.14);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.052), rgba(255, 255, 255, 0.018)),
      rgba(7, 13, 23, 0.92);
  }

  .narrative-panel {
    padding: 24px;
  }

  .narrative-panel h2,
  .repo-cta h2 {
    margin: 0 0 12px;
    color: var(--text-strong);
    font-size: clamp(1.35rem, 2.1vw, 2rem);
    line-height: 1.15;
    letter-spacing: 0;
  }

  .narrative-panel p,
  .walk-card p,
  .repo-cta p {
    margin: 0;
    color: var(--muted);
  }

  .narrative-panel ul {
    margin: 0;
    padding-left: 20px;
    color: var(--muted);
  }

  .narrative-panel li + li {
    margin-top: 8px;
  }

  .walkthrough-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .walk-card {
    min-height: 100%;
    padding: 20px;
  }

  .walk-card span {
    color: var(--amber);
    font-size: 0.76rem;
    font-weight: 950;
    letter-spacing: 0.1em;
  }

  .walk-card h3 {
    margin: 12px 0 8px;
    color: var(--text-strong);
    font-size: 1.08rem;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .repo-cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: center;
    padding: 26px;
  }

  .fallback {
    padding: 24px;
  }

  @media (max-width: 1040px) {
    .walkthrough-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 820px) {
    .narrative-grid,
    .repo-cta {
      grid-template-columns: 1fr;
    }

    .walkthrough-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
