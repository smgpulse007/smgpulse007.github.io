---
import Layout from '../components/Layout.astro';
import CareerField from '../components/v23/CareerField.astro';
import { careerStages, v23Identity } from '../data/v23';
import { education, certifications } from '../data/experience';
const roles=[
  {period:'2026 — present',title:'Applied AI Engineer Consultant',organization:'MetLife via Bizintex',summary:'Production claims and document agents with typed workflow state, validation, exception routing, evaluation, observability, and explicit human authority.',proof:['≈90% lower document-handling effort in a measured workstream','≈50% shorter time-to-payable in a supported workstream']},
  {period:'2023 — 2025',title:'Lead DS/ML Engineer Consultant',organization:'Inland Empire Health Plan via Infowave',summary:'Predictive healthcare ML, local OCR/RAG, HEDIS evidence extraction, transportation FWA analytics, interoperability, MLOps, and operational reporting.',proof:['7K-case backlog cleared','≈90% review-time reduction','20% automated measure-closure improvement','18% transportation waste reduction']},
  {period:'2021 — 2023',title:'Lead Data Scientist / Product',organization:'Hexplora Predictive Analytics',summary:'Built a 0-to-1 healthcare analytics platform across nine programs, connecting risk models, data delivery, embedded analytics, and care-manager workflows.',proof:['$500K new revenue supported','≈$3M client P4P impact supported','≈50% faster model-deployment cycles']},
  {period:'2020 — 2021',title:'Data and analytics engagements',organization:'CommonSpirit Health · Health New England via Infowave',summary:'Hospital operations and provider-data analytics, validation, reporting, and workflow automation.',proof:['Analytics spanning 142 hospitals','100K+ provider records validated','60% lower manual provider-review effort']},
  {period:'2020 — 2021',title:'Data Scientist',organization:'Hexplora Healthcare Analytics',summary:'Explainable readmission modeling, healthcare ETL and automation, and the early product foundation that later scaled across programs.',proof:['Predictive modeling moved into operational analytics','Reusable product and delivery patterns established']},
  {period:'Scientific foundation',title:'Biomedical informatics and research computing',organization:'University of Chicago · AbbVie',summary:'Clinical signals, genomics, scientific computing, statistical modeling, and research communication established the evidence discipline behind later systems.',proof:['M.S. Biomedical Informatics','Clinical sensor and genomics work','Public-health modeling training']},
];
---
<Layout title="Experience — Shailesh Dudala" description="Experience across scientific computing, predictive healthcare ML, analytics products, document intelligence, MLOps, and production agentic AI." canonicalPath="/experience/">
  <section class="v23-page-hero experience-v23-hero"><div class="shell"><p class="v23-kicker">EXPERIENCE / {v23Identity.role}</p><div><h1>The scope widened. The evidence discipline stayed.</h1><p>{v23Identity.shortBio} This page separates career stages from exact roles so the professional record remains legible.</p></div></div></section>
  <section class="v23-section"><div class="shell"><CareerField /></div></section>
  <section class="v23-section role-chronology"><div class="shell v23-section-heading"><div><p class="v23-kicker">Role chronology</p><h2>Professional context, contribution, and outcomes.</h2></div><p>Overlapping 2020–2021 work is kept separate from the academic/research foundation.</p></div><div class="shell role-ledger">{roles.map((role,index)=><article id={careerStages[index]?.id}><div class="role-period"><span>{String(index+1).padStart(2,'0')}</span><strong>{role.period}</strong></div><div class="role-story"><small>{role.organization}</small><h3>{role.title}</h3><p>{role.summary}</p></div><ul>{role.proof.map((proof)=><li>{proof}</li>)}</ul></article>)}</div></section>
  <section class="v23-section experience-methods"><div class="shell v23-section-heading"><div><p class="v23-kicker">Methods by era</p><h2>Tools change. Judgment compounds.</h2></div><p>Each stage added a new layer without erasing the statistical and data foundations beneath it.</p></div><div class="shell method-eras">{careerStages.map((stage)=><article><span>{stage.label}</span><h3>{stage.title}</h3><p>{stage.summary}</p><ul>{stage.methods.map((method)=><li>{method}</li>)}</ul></article>)}</div></section>
  <section class="v23-section credentials-v23"><div class="shell credentials-grid"><div><p class="v23-kicker">Education</p>{education.map((item)=><p>{item}</p>)}</div><div><p class="v23-kicker">Credentials</p>{certifications.map((item)=><p>{item}</p>)}</div><div><p class="v23-kicker">Leadership pattern</p><p>Translate between operations, domain experts, data, models, platforms, and reviewers.</p><p>Make uncertainty, ownership, and release evidence explicit before scale.</p></div></div></section>
  <section class="v23-inline-contact"><div class="shell"><p>Prefer the evidence by system?</p><a href="/work/">Explore professional work →</a><a href="/resume/">Open the public résumé ↗</a></div></section>
</Layout>
