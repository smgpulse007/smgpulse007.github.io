---
import { navigation, profile } from '../data/profile';
---

<a class="skip-link" href="#main-content">Skip to content</a>
<header class="site-header">
  <nav class="shell nav-shell" aria-label="Primary navigation">
    <a class="brand" href="/">
      <span class="brand-mark" aria-hidden="true">SD</span>
      <span class="brand-copy"><strong>{profile.name}</strong><small>Applied AI systems</small></span>
    </a>
    <div class="desktop-nav">
      {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>
    <details class="mobile-nav">
      <summary>Menu</summary>
      <div>
        {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
        <a href={profile.github}>GitHub ↗</a>
        <a href={profile.linkedin}>LinkedIn ↗</a>
      </div>
    </details>
  </nav>
</header>
