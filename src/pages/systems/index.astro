---
import Layout from '@components/Layout.astro';
import ProjectFilterTabs from '@components/ProjectFilterTabs.astro';
import SectionHeader from '@components/SectionHeader.astro';
import { profile } from '@data/profile';
import { projects } from '@data/projects';
---

<Layout
  title={`Systems Library | ${profile.name}`}
  description="Filterable systems and project library spanning healthcare AI, insurance AI, agentic AI, document AI, quant finance, sports forecasting, MLOps, and data science."
  canonicalPath="/systems/"
>
  <section class="section intro">
    <div class="container">
      <p class="section-kicker">Systems library</p>
      <h1>Curated public systems across healthcare, agents, document AI, forecasting, infrastructure, and research.</h1>
      <p class="section-copy">Filter by domain or stack to compare flagship case studies, supporting systems, and research projects that show implementation breadth.</p>
    </div>
  </section>

  <section class="section cards">
    <div class="container">
      <ProjectFilterTabs projects={projects} />
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader
        kicker="Curation"
        title="Every visible system has enough public context to explain what it demonstrates."
        copy="The library favors systems with readable architecture, source-backed examples, and responsible public boundaries over raw repository volume."
      />
    </div>
  </section>
</Layout>

<style>
  .intro {
    padding-bottom: 24px;
  }

  h1 {
    max-width: 1060px;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.6rem, 5.6vw, 5rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .cards {
    padding-top: 20px;
  }

</style>
