---
import Layout from '../../components/Layout.astro';
import FlagshipVisual from '../../components/FlagshipVisual.astro';
import { workItems } from '../../data/work';
import type { WorkItem } from '../../data/types';
import { evidenceAsset } from '../../data/projectEvidence';
import { absoluteUrl } from '../../config/site';

export function getStaticPaths() {
  return workItems.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}
type Props = { item: WorkItem };
const { item } = Astro.props;
const publicType = item.type === 'Research lab' ? 'Public research build' : 'Professional work';
const llmMedia = item.slug === 'llm-steering-lab'
  ? [evidenceAsset('llm-activation-flow'), evidenceAsset('llm-hook-diagram')].filter(Boolean)
  : [];
const jsonLd = [
  {
    '@context': 'https://schema.org', '@type': item.repository ? 'SoftwareSourceCode' : 'CreativeWork',
    name: item.title, description: item.lede, url: absoluteUrl(`/work/${item.slug}/`, true),
    author: { '@type': 'Person', name: 'Shailesh Dudala' }, codeRepository: item.repository,
  },
  {
    '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: absoluteUrl('/', true) },
      { '@type': 'ListItem', position: 2, name: 'Work', item: absoluteUrl('/work/', true) },
      { '@type': 'ListItem', position: 3, name: item.title },
    ],
  },
];
---
<Layout title={item.seo.title} description={item.seo.description} canonicalPath={`/work/${item.slug}/`} type="article" jsonLd={jsonLd}>
  <article class:list={['case-study', `accent-${item.accent}`, `case-${item.visual}`]}>
    <header class="case-hero"><div class="shell case-hero-grid">
      <div class="case-hero-copy"><a class="back-link" href="/work/">← Selected work</a><p class="eyebrow">{item.eyebrow}</p><h1>{item.title}</h1><p class="case-lede">{item.lede}</p><div class="case-tags"><span>{publicType}</span><span>{item.timeframe}</span></div></div>
      <FlagshipVisual item={item} />
    </div></header>

    <div class="shell case-overview">
      <section class="glance-grid" aria-label="90-second overview">{item.glance.map((fact) => <div><span>{fact.label}</span><strong>{fact.value}</strong></div>)}</section>
      <section class="outcome-callout"><span>Result</span><p>{item.outcome}</p></section>
      <nav class="case-toc" aria-label="Case study sections"><span>Deep dive</span>{item.sections.map((section, index) => <a href={`#section-${index + 1}`}>{String(index + 1).padStart(2, '0')} {section.heading}</a>)}<a href="#source-notes">Source notes</a></nav>
    </div>

    <div class="shell case-main">
      {item.sections.map((section, index) => <section id={`section-${index + 1}`} class="case-section"><div class="section-number">{String(index + 1).padStart(2, '0')}</div><div><h2>{section.heading}</h2>{section.body.map((paragraph) => <p>{paragraph}</p>)}{section.bullets && <ul>{section.bullets.map((bullet) => <li>{bullet}</li>)}</ul>}</div></section>)}

      {llmMedia.length > 0 && <section class="case-section source-gallery"><div class="section-number">A</div><div><p class="eyebrow">Repository artifacts</p><h2>The intervention is visible in the checked-in design.</h2><div class="source-gallery-grid">{llmMedia.map((asset) => asset && <figure><img src={asset.path} alt={asset.alt} width="1400" height={asset.id === 'llm-hook-diagram' ? '420' : '560'} loading="lazy" /><figcaption>{asset.caption}</figcaption></figure>)}</div></div></section>}

      <section class="case-section source-notes" id="source-notes"><div class="section-number">S</div><div><p class="eyebrow">Source notes</p><h2>What you can inspect—and what remains private.</h2><div class="evidence-cards">{item.evidence.map((evidence) => <article><h3>{evidence.label}</h3><p>{evidence.detail}</p>{evidence.href && <a href={evidence.href}>Open source ↗</a>}</article>)}</div><h3>Limits</h3><ul>{item.limitations.map((limitation) => <li>{limitation}</li>)}</ul><p class="privacy-boundary">{item.privacyBoundary}</p><details class="artifact-source"><summary>{item.artifact.label}</summary><pre><code>{item.artifact.code}</code></pre></details></div></section>
      <nav class="case-next" aria-label="Case study navigation"><a href="/work/">All work</a><a href="/experience/">Experience →</a></nav>
    </div>
  </article>
</Layout>
