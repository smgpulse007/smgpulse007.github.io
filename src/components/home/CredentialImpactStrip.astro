---
import AnimatedMetricStrip from '@components/visual/AnimatedMetricStrip';
import { impactMetrics, profile } from '@data/profile';
---

<section class="section impact-strip" aria-labelledby="impact-strip-title">
  <div class="container">
    <div class="impact-shell">
      <div class="impact-header">
        <p class="section-kicker">Selected outcomes</p>
        <h2 id="impact-strip-title">Delivery metrics from healthcare, insurance, and applied AI systems work.</h2>
        <p>{profile.impactNote}</p>
      </div>

      <div class="impact-note" aria-label="Outcome framing">
        <span>Operating proof</span>
        <strong>Metrics first, then the systems behind them.</strong>
        <p>Backlog clearance, review acceleration, waste reduction, and deployment speed set the context for the case-study flow below.</p>
      </div>
    </div>

    <AnimatedMetricStrip metrics={impactMetrics} client:load />
  </div>
</section>

<style>
  .impact-strip {
    padding: 66px 0 76px;
    border-block: 1px solid rgba(191, 203, 220, 0.12);
    background:
      radial-gradient(circle at 18% 0%, rgba(241, 189, 92, 0.11), transparent 22rem),
      radial-gradient(circle at 88% 84%, rgba(141, 232, 180, 0.1), transparent 24rem),
      linear-gradient(90deg, rgba(241, 189, 92, 0.065), transparent 30%, rgba(141, 232, 180, 0.06), transparent 70%, rgba(88, 220, 230, 0.045)),
      rgba(5, 9, 15, 0.76);
  }

  .impact-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.42fr);
    gap: 24px;
    align-items: end;
    margin-bottom: 24px;
  }

  .impact-header {
    display: grid;
    gap: 10px;
    max-width: 980px;
  }

  .impact-header h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 3vw, 3rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .impact-header p:not(.section-kicker) {
    max-width: 760px;
    margin: 0;
    color: var(--muted-2);
    font-size: 0.98rem;
  }

  .impact-note {
    display: grid;
    gap: 8px;
    border: 1px solid rgba(241, 189, 92, 0.2);
    border-radius: 20px;
    padding: 18px;
    background:
      radial-gradient(circle at 20% 0%, rgba(241, 189, 92, 0.13), transparent 12rem),
      rgba(4, 10, 18, 0.54);
    box-shadow: 0 18px 54px rgba(0, 0, 0, 0.18);
  }

  .impact-note span {
    color: var(--amber);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .impact-note strong {
    color: #ffffff;
    font-size: 1.02rem;
    line-height: 1.25;
  }

  .impact-note p {
    margin: 0;
    color: var(--muted-copy);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  @media (max-width: 720px) {
    .impact-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
