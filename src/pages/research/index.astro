---
import Layout from '../../components/Layout.astro';
import { researchItems,researchClusters } from '../../data/research';
const counts=Object.fromEntries(['conference','peer-reviewed','preprint','reporting-guideline','technical-specification'].map((status)=>[status,researchItems.filter((item)=>item.status===status).length]));
---
<Layout title="Research Atlas — Shailesh Dudala" description="A verified, curated map of the papers, benchmarks, and standards behind predictive models, context engineering, agent loops, harnesses, and healthcare interoperability." canonicalPath="/research/">
  <section class="research-hero"><div class="shell"><div><span>RESEARCH ATLAS / VERIFIED 2026-07-13</span><h1>The ideas behind the systems.</h1></div><div><p>A curated map of the papers, benchmarks, and standards that shape how I build predictive models, retrieval systems, agent loops, and execution harnesses.</p><dl>{Object.entries(counts).map(([status,count])=><div><dt>{status.replaceAll('-',' ')}</dt><dd>{count}</dd></div>)}</dl></div></div></section>
  <section class="research-product" data-research-product><div class="shell research-toolbar"><div role="tablist" aria-label="Research Atlas views"><button type="button" role="tab" aria-selected="true" data-research-view="constellation">Constellation</button><button type="button" role="tab" aria-selected="false" data-research-view="timeline">Timeline</button><button type="button" role="tab" aria-selected="false" data-research-view="reading">Reading list</button></div><label>Filter cluster<select data-research-filter><option value="all">All clusters</option>{researchClusters.map((cluster)=><option value={cluster}>{cluster}</option>)}</select></label><p aria-live="polite" data-research-count>{researchItems.length} primary records</p></div>
    <div class="shell research-constellation" data-view-panel="constellation"><div class="constellation-field" role="img" aria-label="Research clusters connected to portfolio systems">{researchClusters.map((cluster,i)=><i style={`--angle:${i*45}deg;--radius:${i%2?36:44}%`}><span>{cluster}</span><b>{researchItems.filter((item)=>item.cluster===cluster).length}</b></i>)}<strong>SYSTEMS<br/>OBSERVATORY</strong></div><p>Edges mean informs or relates to. They do not imply a direct citation unless the individual record says so.</p></div>
    <div class="shell research-timeline" data-view-panel="timeline" hidden>{[2005,2010,2015,2020,2025,2026].map((year,i)=><article><span>{year}</span><i></i><div>{researchItems.filter((item)=>item.year>=(i?year:0)&&item.year<(i<5?[2010,2015,2020,2025,2026,3000][i]:3000)).map((item)=><a href={item.source}>{item.title}<small>{item.status}</small></a>)}</div></article>)}</div>
    <div class="shell research-reading" data-view-panel="reading" hidden><div class="research-clusters">{researchClusters.map((cluster)=><button type="button" data-cluster-button={cluster}>{cluster}</button>)}</div><div class="research-list">{researchItems.map((entry)=><article data-research-item data-cluster={entry.cluster}><div><span>{entry.year}</span><i>{entry.status.replaceAll('-',' ')}</i></div><div><h2>{entry.title}</h2><p>{entry.summary}</p><small>{entry.venue} · Appears in: {entry.appearsIn.join(', ')}</small></div><a href={entry.source} aria-label={`Open primary source for ${entry.title}`}>Primary source ↗</a></article>)}</div></div>
  </section>
  <section class="v22-scene atlas-method"><div class="shell"><div><span>STATUS + COPYRIGHT</span><h2>Source-aware by construction.</h2></div><div><p>Conference, peer-reviewed, preprint, reporting guideline, and technical specification are distinct labels.</p><p>No PDF page, publisher figure, journal logo, or long abstract is reproduced. Summaries are original implementation notes.</p><p>The 2026 Meta-Harness paper is separate from Shailesh’s open-source `meta-harness` project; no affiliation or derivation is implied.</p></div></div></section>
</Layout>
<script>
  document.querySelectorAll<HTMLElement>('[data-research-product]').forEach((root)=>{const tabs=[...root.querySelectorAll<HTMLButtonElement>('[data-research-view]')];const panels=[...root.querySelectorAll<HTMLElement>('[data-view-panel]')];tabs.forEach((tab)=>tab.addEventListener('click',()=>{tabs.forEach((item)=>item.setAttribute('aria-selected',String(item===tab)));panels.forEach((panel)=>panel.hidden=panel.dataset.viewPanel!==tab.dataset.researchView)}));const select=root.querySelector<HTMLSelectElement>('[data-research-filter]');const items=[...root.querySelectorAll<HTMLElement>('[data-research-item]')];const count=root.querySelector<HTMLElement>('[data-research-count]');select?.addEventListener('change',()=>{let n=0;items.forEach((item)=>{item.hidden=select.value!=='all'&&item.dataset.cluster!==select.value;if(!item.hidden)n++});if(count)count.textContent=`${n} primary records`});root.querySelectorAll<HTMLButtonElement>('[data-cluster-button]').forEach((button)=>button.addEventListener('click',()=>{const value=button.dataset.clusterButton??'all';if(select){select.value=value;select.dispatchEvent(new Event('change'))}}))});
</script>
