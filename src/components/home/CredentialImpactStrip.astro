---
import AnimatedMetricStrip from '@components/visual/AnimatedMetricStrip';
import { impactMetrics, profile } from '@data/profile';
---

<section class="section impact-strip" aria-labelledby="impact-strip-title">
  <div class="container">
    <div class="impact-header">
      <p class="section-kicker">Selected outcomes</p>
      <h2 id="impact-strip-title">Delivery metrics from healthcare, insurance, and applied AI systems work.</h2>
      <p>{profile.impactNote}</p>
    </div>

    <AnimatedMetricStrip metrics={impactMetrics} client:load />
  </div>
</section>

<style>
  .impact-strip {
    padding: 58px 0 68px;
    border-block: 1px solid rgba(191, 203, 220, 0.12);
    background:
      linear-gradient(90deg, rgba(241, 189, 92, 0.065), transparent 30%, rgba(141, 232, 180, 0.06), transparent 70%, rgba(88, 220, 230, 0.045)),
      rgba(5, 9, 15, 0.76);
  }

  .impact-header {
    display: grid;
    gap: 10px;
    max-width: 980px;
    margin-bottom: 24px;
  }

  .impact-header h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 3vw, 3rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .impact-header p:not(.section-kicker) {
    max-width: 760px;
    margin: 0;
    color: var(--muted-2);
    font-size: 0.98rem;
  }

  @media (max-width: 720px) {
  }
</style>
