---
import '../styles/global.css';
import '../styles/v23/main.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { profile } from '../data/profile';
import { absoluteUrl, siteConfig } from '../config/site';

type Props = {
  title: string;
  description: string;
  canonicalPath?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  noIndex?: boolean;
};

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  image,
  type = 'website',
  jsonLd = [],
  noIndex = false,
} = Astro.props;

const canonicalUrl = absoluteUrl(canonicalPath, true);
const ogSlug = canonicalPath === '/' ? 'home' : canonicalPath.replace(/^\//, '').replace(/\/$/, '').replaceAll('/', '-');
const imageUrl = absoluteUrl(image ?? `/og/${ogSlug}.png`);
const baseJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: profile.name,
    jobTitle: profile.role,
    url: siteConfig.canonicalUrl,
    sameAs: [profile.github, profile.linkedin],
    knowsAbout: ['Agentic AI', 'Document intelligence', 'Healthcare interoperability', 'Predictive ML', 'MLOps'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: `${profile.name} — ${profile.role}`,
    url: siteConfig.canonicalUrl,
    description: profile.seoDescription,
  },
];
const extraJsonLd = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
---

<!doctype html>
<html lang="en" data-visual-tier="reduced" data-motion-paused="false">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={noIndex ? 'noindex,nofollow' : siteConfig.robots} />
    <meta name="theme-color" content="#090b12" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} — Shailesh Dudala portfolio preview`} />
    <meta property="og:site_name" content={`${profile.name} Portfolio`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={`${title} — Shailesh Dudala portfolio preview`} />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
        const reduceTransparency = window.matchMedia('(prefers-reduced-transparency: reduce)');
        const largeViewport = window.matchMedia('(min-width: 1024px)');
        const finePointer = window.matchMedia('(any-pointer: fine)');
        const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
        let webgl2Available;

        const supportsWebgl2 = () => {
          if (webgl2Available !== undefined) return webgl2Available;
          try {
            const canvas = document.createElement('canvas');
            const context = canvas.getContext('webgl2', {
              alpha: false,
              antialias: false,
              powerPreference: 'high-performance',
            });
            webgl2Available = Boolean(context);
            context?.getExtension('WEBGL_lose_context')?.loseContext();
          } catch {
            webgl2Available = false;
          }
          return webgl2Available;
        };

        const classify = () => {
          const effectiveType = connection?.effectiveType ?? '';
          const dataConstrained = Boolean(connection?.saveData) || effectiveType === 'slow-2g' || effectiveType === '2g';
          if (reduceMotion.matches || dataConstrained) {
            root.dataset.visualTier = 'reduced';
            return;
          }

          const cores = Number(navigator.hardwareConcurrency || 0);
          const memory = Number(navigator.deviceMemory || 0);
          const highCapability = cores >= 8 && memory >= 8;
          const enhancedReady = highCapability
            && largeViewport.matches
            && finePointer.matches
            && !reduceTransparency.matches
            && supportsWebgl2();
          root.dataset.visualTier = enhancedReady ? 'enhanced' : 'standard';
        };

        try {
          root.dataset.motionPaused = localStorage.getItem('portfolio:motion-paused') === 'true' ? 'true' : 'false';
        } catch {
          root.dataset.motionPaused = 'false';
        }

        classify();
        [reduceMotion, reduceTransparency, largeViewport, finePointer].forEach((query) => query.addEventListener?.('change', classify));
        connection?.addEventListener?.('change', classify);
      })();
    </script>
    {[...baseJsonLd, ...extraJsonLd].map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <Header />
    <button class="visual-motion-control" type="button" data-motion-toggle aria-pressed="false" aria-label="Pause decorative motion">
      <span class="visual-motion-control__mark" aria-hidden="true"></span>
      <span data-motion-label>Pause motion</span>
    </button>
    {siteConfig.isMirror && (
      <aside class="target-banner">Mirror copy · Canonical portfolio: <a href="https://shaileshdudala.com">shaileshdudala.com</a></aside>
    )}
    {siteConfig.isStaging && <aside class="target-banner">Hostinger staging · Not indexed</aside>}
    <main id="main-content"><slot /></main>
    <Footer />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const control = document.querySelector('[data-motion-toggle]');
        const label = control?.querySelector('[data-motion-label]');
        if (!(control instanceof HTMLButtonElement) || !label) return;

        const render = () => {
          const paused = root.dataset.motionPaused === 'true';
          control.setAttribute('aria-pressed', String(paused));
          control.setAttribute('aria-label', paused ? 'Resume decorative motion' : 'Pause decorative motion');
          label.textContent = paused ? 'Resume motion' : 'Pause motion';
        };

        control.addEventListener('click', () => {
          const paused = root.dataset.motionPaused !== 'true';
          root.dataset.motionPaused = String(paused);
          try {
            localStorage.setItem('portfolio:motion-paused', String(paused));
          } catch {
            // The preference remains active for this page when storage is unavailable.
          }
          render();
        });
        render();
      })();
    </script>
  </body>
</html>
