---
import Layout from '../components/Layout.astro';
import { certifications, education, experienceEras } from '../data/experience';
import { publicImpactClaims } from '../data/impactClaims';
---
<Layout title="Experience — Shailesh Dudala" description="Career progression from biomedical data and healthcare analytics to on-prem GenAI and agentic insurance workflows." canonicalPath="/experience/">
  <section class="page-hero"><div class="shell"><p class="eyebrow">Experience</p><h1>From biomedical data to accountable AI workflows.</h1><p>My scope has expanded from analysis and prediction to product leadership, local GenAI platforms, and agentic claims systems. The constant is making uncertainty operationally visible.</p></div></section>
  <section class="section"><div class="shell experience-page">
    {experienceEras.map((era, index) => <article class="era-card"><div class="era-marker"><span>{String(index + 1).padStart(2, '0')}</span><i></i></div><div class="era-copy"><p class="eyebrow">{era.period}</p><h2>{era.theme}</h2><h3>{era.organization}</h3><strong>{era.title}</strong><p>{era.summary}</p><div class="judgment"><span>Technical judgment</span><p>{era.judgment}</p></div></div><ul>{era.outcomes.map((outcome) => <li>{outcome}</li>)}</ul></article>)}
  </div></section>
  <section class="section paper-section"><div class="shell evidence-ledger"><div><p class="eyebrow">Impact ledger</p><h2>Every public number keeps its context.</h2><p>These values are drawn from the latest résumé and are not combined into a single-project story.</p></div><div>{publicImpactClaims.map((claim) => <article><strong>{claim.value}</strong><h3>{claim.label}</h3><p>{claim.context}</p><small>{claim.evidenceStatus}{claim.qualification ? ` · ${claim.qualification}` : ''}</small></article>)}</div></div></section>
  <section class="section"><div class="shell credentials-grid"><div><p class="eyebrow">Education</p><h2>Biomedical informatics and public-health foundations.</h2><ul>{education.map((item) => <li>{item}</li>)}</ul></div><div><p class="eyebrow">Selected certifications</p><ul>{certifications.map((item) => <li>{item}</li>)}</ul></div></div></section>
</Layout>
