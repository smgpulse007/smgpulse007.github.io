---
import type { CaseStudyDetail } from '@data/caseStudies';

type Props = {
  detail: CaseStudyDetail;
};

const { detail } = Astro.props;
---

<section class="glance-grid" aria-label="Case study at a glance">
  <article class="glance-card glass-card lead">
    <p class="section-kicker">System thesis</p>
    <h2>{detail.thesis}</h2>
    <div class="meta-grid">
      <span><strong>Type</strong>{detail.systemType}</span>
      <span><strong>Users</strong>{detail.primaryUsers}</span>
      <span><strong>Maturity</strong>{detail.artifactMaturity}</span>
    </div>
  </article>
  <article class="glance-card glass-card">
    <p class="section-kicker">At a glance</p>
    <dl>
      {detail.atAGlance.map((item) => (
        <>
          <dt>{item.label}</dt>
          <dd>{item.value}</dd>
        </>
      ))}
    </dl>
  </article>
</section>

<style>
  .glance-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.75fr);
    gap: 18px;
  }

  .glance-card {
    padding: 24px;
  }

  h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.55rem, 2.4vw, 2.35rem);
    line-height: 1.08;
    letter-spacing: 0;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 24px;
  }

  .meta-grid span,
  dl {
    margin: 0;
    color: var(--muted);
  }

  .meta-grid span {
    display: grid;
    gap: 4px;
    border: 1px solid rgba(180, 202, 232, 0.14);
    border-radius: 8px;
    padding: 12px;
    background: rgba(255, 255, 255, 0.04);
  }

  strong,
  dt {
    color: var(--cyan);
    font-size: 0.74rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  dd {
    margin: 4px 0 16px;
    color: var(--text);
  }

  dd:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 860px) {
    .glance-grid,
    .meta-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
