---
import Badge from '@components/ui/Badge.astro';
import { professionalSystems } from '@data/professionalSystems';

const previewSystems = professionalSystems.slice(0, 6);
---

<div class="professional-preview">
  <div class="professional-disclaimer">
    <p>Enterprise systems are described as sanitized architecture patterns. No PHI, PII, employer-confidential data, or proprietary workflows are included.</p>
  </div>
  <div class="professional-preview-grid">
    {previewSystems.map((system, index) => (
      <a class:list={['preview-card', index === 0 && 'lead']} href="/professional-systems/">
        <span>Enterprise system {String(index + 1).padStart(2, '0')}</span>
        <h3>{system.title}</h3>
        <p>{system.thesis}</p>
        <div class="mini-flow" aria-label={`${system.title} architecture summary`}>
          {system.architecture.slice(0, 4).map((step) => <i>{step}</i>)}
        </div>
        <div class="stack">
          {system.stack.slice(0, 4).map((item) => <Badge tone="slate">{item}</Badge>)}
        </div>
        <strong>{system.outcome}</strong>
      </a>
    ))}
  </div>
</div>

<style>
  .professional-preview {
    display: grid;
    gap: 16px;
  }

  .professional-disclaimer {
    border: 1px solid rgba(141, 232, 180, 0.18);
    border-radius: 18px;
    padding: 14px 16px;
    background: rgba(141, 232, 180, 0.055);
  }

  .professional-disclaimer p {
    margin: 0;
    color: #e8fff1;
    font-size: 0.94rem;
  }

  .professional-preview-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .preview-card {
    display: grid;
    gap: 14px;
    min-height: 100%;
    border: 1px solid rgba(191, 203, 220, 0.14);
    border-radius: 24px;
    padding: 20px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.02)),
      rgba(7, 13, 23, 0.9);
    transition:
      transform var(--duration) ease,
      border-color var(--duration) ease,
      box-shadow var(--duration) ease;
  }

  .preview-card:hover {
    transform: translateY(-3px);
    border-color: rgba(141, 232, 180, 0.34);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.32);
  }

  .preview-card.lead {
    grid-column: span 2;
  }

  .preview-card > span {
    color: var(--green);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.18rem, 2vw, 1.82rem);
    line-height: 1.12;
    letter-spacing: 0;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  .mini-flow {
    display: grid;
    gap: 7px;
    border: 1px solid rgba(191, 203, 220, 0.12);
    border-radius: 16px;
    padding: 10px;
    background: rgba(2, 6, 12, 0.42);
  }

  .mini-flow i {
    border-left: 2px solid rgba(88, 220, 230, 0.56);
    padding: 6px 9px;
    background: rgba(88, 220, 230, 0.055);
    color: #dffbff;
    font-size: 0.8rem;
    font-style: normal;
    font-weight: 850;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .preview-card strong {
    margin-top: auto;
    color: #e8fff1;
    font-size: 0.9rem;
    line-height: 1.45;
  }

  @media (max-width: 980px) {
    .professional-preview-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .professional-preview-grid {
      grid-template-columns: 1fr;
    }

    .preview-card.lead {
      grid-column: auto;
    }
  }
</style>
