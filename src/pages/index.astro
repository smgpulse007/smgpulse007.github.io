---
import Layout from '../components/Layout.astro';
import FlightRecorder from '../components/FlightRecorder';
import ImpactStrip from '../components/ImpactStrip.astro';
import SectionIntro from '../components/SectionIntro.astro';
import WorkFeature from '../components/WorkFeature.astro';
import { profile } from '../data/profile';
import { featuredWork } from '../data/work';
import { experienceEras } from '../data/experience';
import { recognition } from '../data/recognition';
import { labItems } from '../data/lab';
---

<Layout title={profile.seoTitle} description={profile.seoDescription} canonicalPath="/">
  <section class="hero-section">
    <div class="shell hero-intro">
      <div class="hero-copy">
        <p class="hero-overline">Senior Applied AI Engineer <i>·</i> Healthcare &amp; Insurance</p>
        <p class="hero-name">Shailesh Dudala</p>
        <h1>I build AI systems that survive real operations.</h1>
      </div>
      <div class="hero-context">
        <p>Claim packets, clinical documents, and event streams rarely arrive ready for a model. I design the contracts, validation, human review, and observability that turn them into accountable workflows.</p>
        <p class="hero-domains">Agentic workflows <i>·</i> Document intelligence <i>·</i> ML platforms</p>
        <div class="hero-actions">
          <a class="button primary" href="/work/">Explore the systems</a>
          <a class="button quiet" href="/resume/">Public résumé</a>
        </div>
        <div class="hero-links"><a href={profile.github}>GitHub ↗</a><a href={profile.linkedin}>LinkedIn ↗</a><a href={`mailto:${profile.email}`}>Email ↗</a></div>
      </div>
    </div>
    <div class="shell hero-instrument"><FlightRecorder client:visible /></div>
  </section>

  <ImpactStrip />

  <section class="section selected-work" id="work">
    <div class="shell">
      <SectionIntro eyebrow="Selected work" title="The systems behind the outcomes." body="Three professional stories and one public research build. Each focuses on the decisions a model cannot own alone." />
      <div class="work-stack">
        {featuredWork.map((item, index) => <WorkFeature item={item} index={index + 1} lead={index === 0} />)}
      </div>
      <a class="section-link" href="/work/">Browse selected work <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <section class="section operating-section">
    <div class="shell operating-layout">
      <div><p class="eyebrow">How I build</p><h2>A model answer is an input to a decision—not the decision itself.</h2></div>
      <ol class="operating-thread">
        <li><span>01</span><strong>Contract</strong><small>Make the output shape explicit.</small></li>
        <li><span>02</span><strong>Evaluate</strong><small>Test failure modes before scale.</small></li>
        <li><span>03</span><strong>Route</strong><small>Send uncertainty with a reason.</small></li>
        <li><span>04</span><strong>Review</strong><small>Keep people in authority.</small></li>
        <li><span>05</span><strong>Observe</strong><small>Measure what happens in use.</small></li>
      </ol>
    </div>
  </section>

  <section class="section experience-preview">
    <div class="shell">
      <SectionIntro eyebrow="Experience" title="The scope widened. The operating question stayed the same." body="Biomedical data became healthcare prediction, then analytics products, local AI, and agentic insurance workflows." />
      <div class="experience-river">
        {experienceEras.map((era, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <div><p>{era.period}</p><h3>{era.theme}</h3><strong>{era.organization}</strong><p>{era.summary}</p></div>
            <ul>{era.outcomes.slice(0, 2).map((outcome) => <li>{outcome}</li>)}</ul>
          </article>
        ))}
      </div>
      <a class="section-link" href="/experience/">Read the experience story <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <section class="section recognition-section">
    <div class="shell recognition-layout">
      <div><p class="eyebrow">Recognition</p><h2>Team work, credited as team work.</h2><p>Let’s Talk Doc belongs here: meaningful recognition with the project and contributors kept attached.</p><a class="section-link" href="/recognition/">See recognition <span aria-hidden="true">→</span></a></div>
      <div class="recognition-list">
        {recognition.slice(0, 2).map((item, index) => <article class:list={{ featured: index === 0 }}><span>{item.attribution}</span><h3>{item.title}</h3><p>{item.project}</p></article>)}
      </div>
    </div>
  </section>

  <section class="section lab-teaser">
    <div class="shell lab-teaser-layout">
      <div><p class="eyebrow">Lab</p><h2>Public builds for the questions that keep expanding the work.</h2><p>Local model behavior, healthcare interoperability, document extraction, and forecasting—organized by maturity and limitation.</p><a class="button quiet" href="/lab/">Enter the Lab</a></div>
      <div class="lab-teaser-list">
        {labItems.slice(0, 3).map((item, index) => <a href={`/lab/${item.slug}/`}><span>{String(index + 1).padStart(2, '0')}</span><div><strong>{item.title}</strong><small>{item.domain}</small></div><i>→</i></a>)}
      </div>
    </div>
  </section>

  <section class="section about-teaser">
    <div class="shell about-teaser-layout">
      <p class="eyebrow">Origin</p>
      <blockquote>“I started in biomedical informatics, where every result had to survive contact with messy clinical context. That lesson still shapes how I build AI.”</blockquote>
      <div><p>The throughline is not a favorite model. It is making uncertainty legible enough for people to act responsibly.</p><a class="section-link" href="/about/">More about how I work <span aria-hidden="true">→</span></a></div>
    </div>
  </section>

  <section class="section contact-section" id="contact">
    <div class="shell contact-layout">
      <div><p class="eyebrow">Contact</p><h2>Working on a system where an AI answer has to become a defensible action?</h2><p>Let’s talk about the architecture between those two points.</p></div>
      <div class="contact-actions"><a class="button primary" href={`mailto:${profile.email}`}>Email Shailesh</a><a href={profile.linkedin}>LinkedIn ↗</a><a href={profile.github}>GitHub ↗</a><a href="/resume/">Public résumé →</a></div>
    </div>
  </section>
</Layout>
