---
const artifacts = [
  {
    kicker: 'LLM Steering',
    title: 'Workbench UI from the local activation-steering lab',
    body:
      'Actual repo artifact showing the FastAPI + React workbench used to inspect steering runs, hook choices, and baseline comparisons.',
    src: '/assets/case-studies/llm-steering/workbench-ui-overview.gif',
    alt: 'Animated LLM steering workbench UI overview',
  },
  {
    kicker: 'AlphaQuant',
    title: 'Agentic research workbench screenshot',
    body:
      'Actual repo screenshot from the local-first agentic market-intelligence stack with API, UI, storage, retrieval, and verification layers.',
    src: '/assets/case-studies/alphaquant/ui-screenshot.png',
    alt: 'AlphaQuant UI screenshot',
  },
  {
    kicker: 'HL7 AI Challenge',
    title: 'Event-driven healthcare platform architecture',
    body:
      'Challenge architecture evidence for HL7/FHIR transformation, risk services, care orchestration, workflow surfaces, and audit flow.',
    src: '/assets/case-studies/hl7/architecture-high-level.png',
    alt: 'HL7 AI Challenge high-level architecture diagram',
  },
];
---

<section class="section evidence-section">
  <div class="container">
    <div class="evidence-header">
      <p class="section-kicker">Repo evidence</p>
      <h2>Real artifacts from the systems, not decorative placeholders.</h2>
      <p>
        The redesign pulls screenshots, GIFs, diagrams, JSON responses, and model tables from the public repositories so the
        portfolio reads like engineering proof.
      </p>
    </div>

    <div class="evidence-grid">
      {artifacts.map((artifact, index) => (
        <article class:list={['evidence-card', 'glass-card', index === 0 && 'lead']}>
          <img src={artifact.src} alt={artifact.alt} loading={index === 0 ? 'eager' : 'lazy'} />
          <div>
            <span>{artifact.kicker}</span>
            <h3>{artifact.title}</h3>
            <p>{artifact.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .evidence-section {
    padding-top: 34px;
  }

  .evidence-header {
    max-width: 920px;
    margin-bottom: 24px;
  }

  .evidence-header h2 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.9rem, 3.4vw, 3.3rem);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .evidence-header p:last-child {
    max-width: 760px;
    margin: 14px 0 0;
    color: var(--muted);
    font-size: 1.04rem;
  }

  .evidence-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 0.95fr);
    gap: 18px;
  }

  .evidence-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 14px;
  }

  .evidence-card.lead {
    grid-row: span 2;
  }

  .evidence-card img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    border: 1px solid rgba(180, 202, 232, 0.16);
    border-radius: 8px;
    background: #05070c;
    object-fit: cover;
  }

  .evidence-card.lead img {
    aspect-ratio: 16 / 11;
  }

  .evidence-card div {
    padding: 0 4px 4px;
  }

  .evidence-card span {
    color: var(--cyan);
    font-size: 0.74rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .evidence-card h3 {
    margin: 7px 0 8px;
    color: var(--text-strong);
    font-size: clamp(1.08rem, 1.5vw, 1.32rem);
    line-height: 1.17;
    letter-spacing: 0;
  }

  .evidence-card p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .evidence-grid {
      grid-template-columns: 1fr;
    }

    .evidence-card.lead {
      grid-row: auto;
    }
  }
</style>
