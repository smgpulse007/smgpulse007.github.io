---
import Badge from '@components/ui/Badge.astro';
import { professionalSystems } from '@data/professionalSystems';

const previewSystems = professionalSystems.slice(0, 6);
const impactNotes = ['7K backlog cleared', '90% review-time reduction', '18% FWA waste reduction', '$3M P4P impact'];
---

<div class="professional-preview" aria-label="Sanitized professional systems preview">
  <section class="professional-bridge">
    <div class="bridge-copy">
      <p class="section-kicker">Enterprise bridge</p>
      <h3>Public case studies point to the same architecture habits used in regulated delivery.</h3>
      <p>
        The systems below translate professional healthcare and insurance work into sanitized patterns: intake,
        extraction, validation, review, analytics, deployment, and accountable handoff.
      </p>
    </div>
    <div class="bridge-metrics" aria-label="Selected professional impact markers">
      {impactNotes.map((item) => <span>{item}</span>)}
    </div>
  </section>

  <p class="professional-disclaimer">
    Enterprise systems are described as sanitized architecture patterns. No PHI, PII, employer-confidential data, or proprietary workflows are included.
  </p>

  <div class="professional-stream">
    {previewSystems.map((system, index) => (
      <a class:list={['stream-card', index === 0 && 'lead']} href="/professional-systems/">
        <span class="stream-index">{String(index + 1).padStart(2, '0')}</span>
        <div class="stream-copy">
          <span>Enterprise system</span>
          <h3>{system.title}</h3>
          <p>{system.thesis}</p>
        </div>
        <div class="stream-architecture" aria-label={`${system.title} architecture summary`}>
          {system.architecture.slice(0, 5).map((step) => <i>{step}</i>)}
        </div>
        <div class="stream-proof">
          <div class="stack">
            {system.stack.slice(0, 4).map((item) => <Badge tone="slate">{item}</Badge>)}
          </div>
          <strong>{system.outcome}</strong>
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  .professional-preview {
    display: grid;
    gap: 18px;
  }

  .professional-bridge,
  .stream-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(191, 203, 220, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.068), rgba(255, 255, 255, 0.022)),
      rgba(7, 13, 23, 0.92);
    box-shadow: 0 22px 70px rgba(0, 0, 0, 0.28);
  }

  .professional-bridge {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.6fr);
    gap: 24px;
    align-items: end;
    border-radius: 28px;
    padding: 26px;
    background:
      radial-gradient(circle at 10% 0%, rgba(141, 232, 180, 0.16), transparent 17rem),
      radial-gradient(circle at 92% 80%, rgba(88, 220, 230, 0.1), transparent 17rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.024)),
      rgba(7, 13, 23, 0.94);
  }

  .bridge-copy {
    display: grid;
    gap: 12px;
  }

  .bridge-copy h3 {
    max-width: 960px;
    margin: 0;
    color: #ffffff;
    font-size: clamp(1.7rem, 3.4vw, 3.55rem);
    line-height: 1.02;
    letter-spacing: 0;
  }

  .bridge-copy p:not(.section-kicker) {
    max-width: 820px;
    margin: 0;
    color: var(--muted-copy);
    font-size: 1.02rem;
    line-height: 1.55;
  }

  .bridge-metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .bridge-metrics span {
    min-height: 68px;
    border: 1px solid rgba(141, 232, 180, 0.18);
    border-radius: 16px;
    padding: 12px;
    background: rgba(141, 232, 180, 0.055);
    color: #e8fff1;
    font-size: 0.9rem;
    font-weight: 950;
    line-height: 1.2;
  }

  .professional-disclaimer {
    margin: 0;
    border: 1px solid rgba(141, 232, 180, 0.18);
    border-radius: 16px;
    padding: 13px 15px;
    background: rgba(141, 232, 180, 0.055);
    color: #dffbea;
    font-size: 0.9rem;
  }

  .professional-stream {
    display: grid;
    gap: 14px;
  }

  .stream-card {
    display: grid;
    grid-template-columns: 58px minmax(280px, 0.78fr) minmax(0, 1.35fr);
    gap: 14px 18px;
    align-items: center;
    min-height: 178px;
    border-left: 4px solid var(--green);
    border-radius: 22px;
    padding: 18px;
    transition:
      transform var(--duration) ease,
      border-color var(--duration) ease,
      box-shadow var(--duration) ease;
  }

  .stream-card::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: '';
    background:
      linear-gradient(90deg, rgba(141, 232, 180, 0.12), transparent 38%),
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: auto, 32px 32px, 32px 32px;
    opacity: 0.55;
  }

  .stream-card:hover {
    transform: translateY(-3px);
    border-color: rgba(141, 232, 180, 0.42);
    box-shadow: 0 28px 86px rgba(0, 0, 0, 0.35);
  }

  .stream-card > * {
    position: relative;
    z-index: 1;
  }

  .stream-index {
    grid-column: 1;
    grid-row: 1 / span 2;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(141, 232, 180, 0.3);
    border-radius: 999px;
    background: rgba(2, 6, 12, 0.72);
    color: var(--green);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
    font-weight: 950;
  }

  .stream-copy {
    grid-column: 2;
    grid-row: 1 / span 2;
    display: grid;
    gap: 9px;
  }

  .stream-copy > span {
    color: var(--green);
    font-size: 0.7rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .stream-copy h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.2rem, 2vw, 1.85rem);
    line-height: 1.08;
    letter-spacing: 0;
  }

  .stream-copy p {
    margin: 0;
    color: var(--muted-copy);
    font-size: 0.94rem;
    line-height: 1.45;
  }

  .stream-architecture {
    grid-column: 3;
    grid-row: 1;
    display: grid;
    grid-template-columns: repeat(5, minmax(96px, 1fr));
    gap: 7px;
  }

  .stream-architecture i {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 46px;
    border: 1px solid rgba(191, 203, 220, 0.12);
    border-radius: 13px;
    padding: 8px 9px;
    background: rgba(88, 220, 230, 0.055);
    color: #dffbff;
    font-size: 0.72rem;
    font-style: normal;
    font-weight: 850;
    line-height: 1.16;
  }

  .stream-architecture i:not(:last-child)::after {
    position: absolute;
    right: -8px;
    width: 8px;
    height: 1px;
    content: '';
    background: rgba(141, 232, 180, 0.46);
  }

  .stream-proof {
    grid-column: 3;
    grid-row: 2;
    display: grid;
    gap: 11px;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .stream-proof strong {
    color: #e8fff1;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  @media (max-width: 1180px) {
    .professional-bridge,
    .stream-card {
      grid-template-columns: 1fr;
    }

    .stream-index,
    .stream-copy,
    .stream-architecture,
    .stream-proof {
      grid-column: auto;
      grid-row: auto;
    }

    .stream-index {
      align-self: start;
    }
  }

  @media (max-width: 720px) {
    .professional-bridge {
      border-radius: 24px;
      padding: 18px;
    }

    .bridge-metrics,
    .stream-architecture {
      grid-template-columns: 1fr;
    }

    .stream-card {
      min-height: auto;
      padding: 16px;
    }

    .stream-architecture i:not(:last-child)::after {
      display: none;
    }
  }
</style>
