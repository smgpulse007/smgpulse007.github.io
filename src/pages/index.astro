---
import Layout from '@components/Layout.astro';
import Hero from '@components/Hero.astro';
import SectionHeader from '@components/SectionHeader.astro';
import CredentialImpactStrip from '@components/home/CredentialImpactStrip.astro';
import DomainSystemsList from '@components/home/DomainSystemsList';
import FeaturedWork from '@components/home/FeaturedWork.astro';
import ArtifactWall from '@components/home/ArtifactWall';
import ProfessionalSystemsPreview from '@components/home/ProfessionalSystemsPreview.astro';
import { profile } from '@data/profile';
---

<Layout title={profile.seoTitle} description={profile.seoDescription} canonicalPath="/">
  <Hero />

  <CredentialImpactStrip />

  <section class="section domain-section">
    <div class="container">
      <SectionHeader
        kicker="Domains"
        title="A connected map of the systems I build across healthcare AI, claims automation, forecasting, agentic workflows, and MLOps."
        copy="Each row links a domain to a concrete system, the implementation stack behind it, and the path a reviewer can follow next."
      />
      <DomainSystemsList client:load />
    </div>
  </section>

  <section class="section showroom-section">
    <div class="container">
      <SectionHeader
        kicker="Featured work"
        title="Case-study systems with visible architecture, APIs, model tables, screenshots, and demos."
        copy="A flagship healthcare ML API anchors the portfolio, with LLM steering, agentic research infrastructure, forecasting, interoperability, and document AI close behind."
      />
      <FeaturedWork />
    </div>
  </section>

  <section class="section artifact-section section-band">
    <div class="container">
      <SectionHeader
        kicker="Evidence"
        title="Evidence, not just labels."
        copy="Screenshots, GIFs, JSON responses, architecture diagrams, model tables, and synthetic examples are surfaced directly from public-safe repos or generated as labeled portfolio visualizations."
      />
      <ArtifactWall client:load />
    </div>
  </section>

  <section class="section professional-section">
    <div class="container">
      <SectionHeader
        kicker="Professional systems"
        title="Enterprise AI patterns from regulated healthcare and insurance delivery."
        copy="Sanitized architecture maps connect the public portfolio to claims automation, HEDIS evidence extraction, local RAG/OCR, predictive models, FWA analytics, and healthcare analytics platforms."
      />
      <ProfessionalSystemsPreview />
    </div>
  </section>

  <section class="section compact final-cta">
    <div class="container cta-grid">
      <div>
        <p class="section-kicker">Implementation details</p>
        <h2>Explore the case studies, source repos, and professional systems map.</h2>
      </div>
      <div class="cta-actions">
        <a class="button" href="/projects/">Case Studies</a>
        <a class="button secondary" href="/systems/">Systems Library</a>
        <a class="button secondary" href={profile.github}>GitHub</a>
        <a class="button secondary" href={profile.linkedin}>LinkedIn</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .domain-section {
    padding-top: 76px;
  }

  .showroom-section {
    padding-top: 34px;
  }

  .artifact-section,
  .professional-section {
    padding-top: 82px;
  }

  .final-cta {
    border-top: 1px solid rgba(191, 203, 220, 0.12);
    background:
      linear-gradient(90deg, rgba(88, 220, 230, 0.055), transparent 42%, rgba(240, 160, 189, 0.045)),
      rgba(5, 9, 15, 0.82);
  }

  .cta-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: center;
  }

  .cta-grid h2 {
    max-width: 900px;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.7rem, 3.3vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px;
  }

  @media (max-width: 860px) {
    .cta-grid {
      grid-template-columns: 1fr;
    }

    .cta-actions {
      justify-content: flex-start;
    }
  }
</style>
