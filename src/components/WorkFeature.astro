---
import type { WorkItem } from '../data/types';
type Props = { item: WorkItem; index: number; lead?: boolean };
const { item, index, lead = false } = Astro.props;
---
<article class:list={['work-feature', `accent-${item.accent}`, { lead }]}>
  <div class="feature-index" aria-hidden="true">{String(index).padStart(2, '0')}</div>
  <div class="feature-copy">
    <div class="feature-meta"><span>{item.type}</span><span>{item.domain}</span></div>
    <h3>{item.title}</h3>
    <p data-narrative>{item.lede}</p>
    <div class="proof-view" data-proof>
      <strong>{item.outcome}</strong>
      <span>{item.evidence[0]?.classification} · {item.evidence[0]?.detail}</span>
    </div>
    <a class="text-link" href={`/work/${item.slug}/`}>Read case study <span aria-hidden="true">↗</span></a>
  </div>
  <div class="feature-artifact" aria-label={item.artifact.label}>
    <div class="artifact-bar"><span>{item.artifact.label}</span><i>{item.status}</i></div>
    <pre><code>{item.artifact.code}</code></pre>
    <ol aria-label="System flow">
      {item.flow.map((step) => <li>{step}</li>)}
    </ol>
  </div>
</article>

