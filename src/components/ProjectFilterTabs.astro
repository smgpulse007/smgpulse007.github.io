---
import ProjectCard from './ProjectCard.astro';
import { projectFilters, type Project, type ProjectCategory } from '@data/projects';

type Props = {
  projects: Project[];
  filters?: Array<'All' | ProjectCategory>;
  compact?: boolean;
};

const { projects, filters = projectFilters, compact = false } = Astro.props;
---

<section class="project-filter" data-project-filters>
  <div class="filter-tabs" role="tablist" aria-label="Project category filters">
    {filters.map((filter, index) => (
      <button
        type="button"
        class:list={['filter-tab', index === 0 && 'active']}
        data-filter={filter}
        aria-pressed={index === 0 ? 'true' : 'false'}
      >
        {filter}
      </button>
    ))}
  </div>
  <div class="filter-grid card-grid" aria-live="polite">
    {projects.map((project) => <ProjectCard project={project} compact={compact} />)}
  </div>
</section>

<script>
  function initProjectFilters() {
    document.querySelectorAll('[data-project-filters]').forEach((root) => {
      if (root instanceof HTMLElement && root.dataset.ready === 'true') return;
      if (root instanceof HTMLElement) root.dataset.ready = 'true';

      const tabs = Array.from(root.querySelectorAll('[data-filter]'));
      const cards = Array.from(root.querySelectorAll('[data-project-card]'));

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const filter = tab.getAttribute('data-filter') || 'All';
          tabs.forEach((item) => {
            item.classList.toggle('active', item === tab);
            item.setAttribute('aria-pressed', String(item === tab));
          });
          cards.forEach((card) => {
            const categories = card.getAttribute('data-categories') || '';
            card.toggleAttribute('hidden', !(filter === 'All' || categories.split('|').includes(filter)));
          });
        });
      });
    });
  }

  initProjectFilters();
  document.addEventListener('astro:page-load', initProjectFilters);
</script>

<style>
  .project-filter {
    display: grid;
    gap: 24px;
  }

  .filter-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .filter-tab {
    min-height: 40px;
    border: 1px solid rgba(180, 202, 232, 0.2);
    border-radius: 999px;
    padding: 8px 13px;
    background: rgba(255, 255, 255, 0.05);
    color: var(--muted);
    cursor: pointer;
    font-size: 0.86rem;
    font-weight: 900;
  }

  .filter-tab:hover,
  .filter-tab.active {
    border-color: rgba(88, 220, 230, 0.5);
    background: rgba(88, 220, 230, 0.12);
    color: var(--text-strong);
  }

  [hidden] {
    display: none !important;
  }
</style>
