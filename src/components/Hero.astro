---
import { profile } from '@data/profile';
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Applied AI systems portfolio</p>
      <h1>{profile.name}</h1>
      <h2>{profile.role}</h2>
      <p class="lede">{profile.positioning}</p>
      <div class="button-row">
        <a class="button" href="/projects/">View Case Studies</a>
        <a class="button secondary" href="/systems/">Explore Systems</a>
        <a class="button secondary" href="/quant-forecasting/">Quant & Forecasting</a>
      </div>
    </div>
    <div class="hero-art glass-card">
      <img src="/assets/hero-system-map.svg" alt="Applied AI system map showing healthcare interoperability, agentic AI, document AI, ML services, quant systems, and LLMOps." />
      <div class="signal-row" aria-label="Portfolio focus areas">
        <span>Healthcare AI</span>
        <span>Agentic Systems</span>
        <span>Quant Research</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 94px 0 58px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1fr);
    gap: 34px;
    align-items: center;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--cyan);
    font-size: 0.8rem;
    font-weight: 950;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(3.4rem, 8vw, 6.9rem);
    line-height: 0.94;
    letter-spacing: 0;
  }

  h2 {
    margin: 18px 0 0;
    color: var(--cyan);
    font-size: clamp(1.25rem, 2.8vw, 2rem);
    line-height: 1.15;
    letter-spacing: 0;
  }

  .lede {
    max-width: 720px;
    margin: 22px 0 30px;
    color: #d8e6f7;
    font-size: clamp(1.06rem, 2vw, 1.28rem);
  }

  .hero-art {
    padding: 14px;
  }

  .hero-art img {
    display: block;
    width: 100%;
    border-radius: 8px;
  }

  .signal-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin-top: 12px;
  }

  .signal-row span {
    display: grid;
    min-height: 42px;
    place-items: center;
    border: 1px solid rgba(180, 202, 232, 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 900;
    text-align: center;
  }

  @media (max-width: 940px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-art {
      order: -1;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 52px;
    }

    .signal-row {
      grid-template-columns: 1fr;
    }
  }
</style>
