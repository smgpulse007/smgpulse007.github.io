---
import Layout from '@components/Layout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import SectionHeader from '@components/SectionHeader.astro';
import ArchitectureDiagram from '@components/ArchitectureDiagram.astro';
import { profile } from '@data/profile';
import { getProject, type Project } from '@data/projects';

const projects = ['agentic-alpha-engine', 'nfl-sports-forecasting']
  .map((slug) => getProject(slug))
  .filter((project): project is Project => Boolean(project));
---

<Layout
  title={`Quant & Forecasting | ${profile.name}`}
  description="Quant research, agentic market intelligence, sports forecasting, model calibration, and backtesting systems by Shailesh Dudala."
  canonicalPath="/quant-forecasting/"
>
  <section class="section intro">
    <div class="container">
      <p class="section-kicker">Quant & forecasting</p>
      <h1>Forecasting systems, calibration, and agentic research infrastructure.</h1>
      <p class="section-copy">This section shows analytical breadth: public-signal ingestion, forecasting baselines, model comparison, Brier score, historical backtesting, and verification-heavy reporting.</p>
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <SectionHeader kicker="Flagship analytical systems" title="Agentic market research and historical sports forecasting." />
      <div class="two-column-grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="section compact">
    <div class="container visual-grid">
      <article class="visual-panel">
        <div>
          <p class="section-kicker">AlphaQuant workbench</p>
          <h2>Agentic market intelligence as an architecture testbed.</h2>
          <p>Public signals move through adapters, storage, retrieval, planner agents, verification rules, and report surfaces.</p>
        </div>
        <img src="/assets/case-studies/alphaquant/screenshots/ui-demo.gif" alt="AlphaQuant UI demo GIF" loading="lazy" />
      </article>
      <article class="visual-panel">
        <div>
          <p class="section-kicker">Sports Forecasting Lab</p>
          <h2>Baselines and probability quality stay visible.</h2>
          <p>Historical NFL results are framed around model comparison, calibration, Brier score, and backtesting.</p>
        </div>
        <img src="/assets/case-studies/nfl/charts/model-comparison.svg" alt="NFL forecasting model comparison chart" loading="lazy" />
      </article>
    </div>
  </section>

  <section class="section compact">
    <div class="container diagram-stack">
      <SectionHeader kicker="Architecture" title="Forecasting and research pipelines need inspectable flow." copy="AlphaQuant emphasizes agent orchestration and evidence verification. The NFL lab emphasizes baselines, model comparison, calibration, and historical backtesting." />
      <ArchitectureDiagram variant="alphaquant" />
      <ArchitectureDiagram variant="nfl" />
    </div>
  </section>

  <section class="section compact">
    <div class="container disclaimer glass-card">
      <p class="section-kicker">Responsible use</p>
      <h2>Research and engineering demos only.</h2>
      <p>Not investment advice, financial advice, betting advice, gambling advice, live trading automation, or a wagering product.</p>
    </div>
  </section>
</Layout>

<style>
  .intro {
    padding-bottom: 24px;
  }

  h1 {
    max-width: 1040px;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.7rem, 5.8vw, 5.1rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .disclaimer {
    padding: 26px;
  }

  .disclaimer h2 {
    margin: 0 0 10px;
    color: var(--text-strong);
    font-size: clamp(1.5rem, 2.4vw, 2.2rem);
    letter-spacing: 0;
  }

  .disclaimer p:last-child {
    margin: 0;
    color: var(--muted);
  }

  .diagram-stack {
    display: grid;
    gap: 18px;
  }

  .visual-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .visual-panel {
    display: grid;
    gap: 18px;
    overflow: hidden;
    border: 1px solid rgba(191, 203, 220, 0.14);
    border-radius: 24px;
    padding: 20px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.02)),
      rgba(7, 13, 23, 0.9);
  }

  .visual-panel h2 {
    margin: 0 0 10px;
    color: var(--text-strong);
    font-size: clamp(1.35rem, 2.4vw, 2.35rem);
    line-height: 1.1;
    letter-spacing: 0;
  }

  .visual-panel p:not(.section-kicker) {
    margin: 0;
    color: var(--muted);
  }

  .visual-panel img {
    width: 100%;
    border: 1px solid rgba(191, 203, 220, 0.14);
    border-radius: 16px;
    background: #05070c;
  }

  @media (max-width: 860px) {
    .visual-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
