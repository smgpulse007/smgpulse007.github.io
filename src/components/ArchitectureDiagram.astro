---
import type { DiagramVariant } from '@data/projects';

type Zone = {
  label: string;
  tone: 'cyan' | 'green' | 'amber' | 'violet';
  nodes: string[];
};

type Diagram = {
  title: string;
  description: string;
  zones: Zone[];
  footer: string[];
};

type Props = {
  variant: DiagramVariant;
};

const { variant } = Astro.props;

const diagrams: Record<DiagramVariant, Diagram> = {
  readmission: {
    title: 'Layered FHIR risk-scoring API',
    description: 'A standards-aware API path that keeps data contracts, feature extraction, scoring, explanations, and validation separate.',
    zones: [
      { label: 'FHIR Contract', tone: 'cyan', nodes: ['Synthetic bundle', 'FastAPI schema', 'resource validation'] },
      { label: 'Feature Layer', tone: 'green', nodes: ['FHIR parser', 'feature builder', 'risk matrix'] },
      { label: 'Model Layer', tone: 'violet', nodes: ['scorer', 'feature contributions', 'risk band'] },
      { label: 'Validation Layer', tone: 'amber', nodes: ['sample response', 'model card', 'pytest + Docker'] },
    ],
    footer: ['No PHI', 'Synthetic examples', 'Explainable output', 'CI-ready service'],
  },
  hl7: {
    title: 'Event-driven HL7/FHIR quality platform',
    description: 'A microservices architecture where HL7 events, FHIR mapping, risk services, SMART/CDS, and dashboards are independent reviewable layers.',
    zones: [
      { label: 'Event Sources', tone: 'cyan', nodes: ['HL7 ADT', 'HL7 ORU', 'HL7 MDM'] },
      { label: 'Message Bus', tone: 'amber', nodes: ['RabbitMQ', 'event routing', 'async workers'] },
      { label: 'AI Services', tone: 'violet', nodes: ['HL7 processing', 'risk prediction', 'care orchestration'] },
      { label: 'Workflow', tone: 'green', nodes: ['FHIR R4 resources', 'SMART app', 'CDS Hooks', 'dashboard'] },
    ],
    footer: ['PostgreSQL', 'Redis', 'Docker', 'Challenge evidence package'],
  },
  'llm-steering': {
    title: 'Activation steering workbench',
    description: 'A model-internals diagram that exposes prompt pairs, vector extraction, hook placement, comparison runs, and workbench review.',
    zones: [
      { label: 'Experiment Design', tone: 'cyan', nodes: ['positive prompt', 'negative prompt', 'behavior preset'] },
      { label: 'Representation Work', tone: 'violet', nodes: ['hidden states', 'steering vector', 'layer + coefficient'] },
      { label: 'Intervention Site', tone: 'amber', nodes: ['pre-hook', 'post-hook', 'residual stream'] },
      { label: 'Workbench', tone: 'green', nodes: ['FastAPI', 'React UI', 'baseline vs steered'] },
    ],
    footer: ['ActAdd baseline', 'Hugging Face + PyTorch', 'local model access', 'limitations visible'],
  },
  'document-ai': {
    title: 'Local document intelligence boundary',
    description: 'A privacy-oriented pipeline that keeps parsing, chunking, prompt assembly, local inference, and review inside the local workflow.',
    zones: [
      { label: 'Document Zone', tone: 'cyan', nodes: ['local PDF', 'PDFPlumber', 'text extraction'] },
      { label: 'Context Zone', tone: 'green', nodes: ['chunking', 'criteria prompts', 'context windows'] },
      { label: 'Inference Zone', tone: 'violet', nodes: ['LangChain', 'Ollama', 'local model'] },
      { label: 'Review Zone', tone: 'amber', nodes: ['Streamlit UI', 'extracted answer', 'analyst review'] },
    ],
    footer: ['Local-first', 'reviewable output', 'no committed private docs', 'regulated workflow pattern'],
  },
  alphaquant: {
    title: 'Agentic research stack with storage fabric',
    description: 'A local-first agentic system with separate ingestion, memory, planning, verification, and Fusion report surfaces.',
    zones: [
      { label: 'Signal Ingestion', tone: 'cyan', nodes: ['market signals', 'macro context', 'public research'] },
      { label: 'Storage Fabric', tone: 'green', nodes: ['Postgres', 'Redis', 'Qdrant', 'MinIO', 'OpenSearch'] },
      { label: 'Agent Core', tone: 'violet', nodes: ['planner', 'tool calls', 'state graph', 'Ollama'] },
      { label: 'Verification', tone: 'amber', nodes: ['rules', 'citations', 'Fusion report', 'API/UI'] },
    ],
    footer: ['Docker-first', 'local-first', 'not financial advice', 'structured reports'],
  },
  nfl: {
    title: 'Forecasting and backtesting pipeline',
    description: 'A model-evaluation architecture where baselines, supervised models, calibration, and historical backtests are visible.',
    zones: [
      { label: 'Historical Data', tone: 'cyan', nodes: ['1999-2024 games', 'team stats', 'schedule context'] },
      { label: 'Baselines', tone: 'green', nodes: ['Elo ratings', 'home advantage', 'feature matrix'] },
      { label: 'Model Stack', tone: 'violet', nodes: ['XGBoost', 'logistic regression', 'ensemble'] },
      { label: 'Evaluation', tone: 'amber', nodes: ['Brier score', 'accuracy table', 'backtesting'] },
    ],
    footer: ['Historical lab', 'analytics research', 'not betting advice', 'calibration discipline'],
  },
  freshtrack: {
    title: 'OCR-to-JSON extraction API',
    description: 'A document/vision API path where image cleanup, OCR, parsing, optional LLM filtering, confidence, and JSON output are distinct.',
    zones: [
      { label: 'Image Intake', tone: 'cyan', nodes: ['receipt image', 'preprocessing', 'upload API'] },
      { label: 'OCR Layer', tone: 'green', nodes: ['Tesseract', 'raw text', 'noise cleanup'] },
      { label: 'Parser Layer', tone: 'violet', nodes: ['domain matching', 'optional LLM', 'false-positive filter'] },
      { label: 'Contract Layer', tone: 'amber', nodes: ['confidence', 'shelf-life lookup', 'JSON response'] },
    ],
    footer: ['FastAPI docs', 'Docker variants', 'test receipt', 'frontend-ready contract'],
  },
  chatwithwiki: {
    title: 'Azure ML Prompt Flow RAG graph',
    description: 'A cloud RAG workflow that separates public content, retrieval, prompt templating, LLM generation, and answer review.',
    zones: [
      { label: 'Source', tone: 'cyan', nodes: ['public wiki content', 'question', 'retrieval target'] },
      { label: 'Retrieval', tone: 'green', nodes: ['context passages', 'ranking', 'grounding'] },
      { label: 'Prompt Flow', tone: 'violet', nodes: ['Jinja template', 'workflow nodes', 'LLM call'] },
      { label: 'Review', tone: 'amber', nodes: ['answer artifact', 'source check', 'quality notes'] },
    ],
    footer: ['Azure ML', 'Prompt Flow', 'RAG demo', 'public content only'],
  },
};

const diagram = diagrams[variant];
---

<figure class="architecture glass-card">
  <figcaption>
    <span>Custom architecture</span>
    <strong>{diagram.title}</strong>
  </figcaption>
  <p class="description">{diagram.description}</p>
  <div class="architecture-map" data-variant={variant}>
    <svg class="architecture-lines" viewBox="0 0 1000 250" aria-hidden="true" preserveAspectRatio="none">
      <path d="M90 70 C240 20 300 120 420 80 S650 80 770 45 S880 92 950 70" />
      <path d="M90 175 C230 215 330 135 470 180 S710 185 930 145" />
    </svg>
    {diagram.zones.map((zone) => (
      <section class:list={['architecture-zone', zone.tone]}>
        <h3>{zone.label}</h3>
        <div>
          {zone.nodes.map((node) => <span>{node}</span>)}
        </div>
      </section>
    ))}
  </div>
  <div class="architecture-footer">
    {diagram.footer.map((item) => <span>{item}</span>)}
  </div>
</figure>

<style>
  .architecture {
    margin: 0;
    padding: 18px;
  }

  figcaption {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
  }

  figcaption span {
    color: var(--cyan);
    font-size: 0.74rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  figcaption strong {
    color: var(--text-strong);
    font-size: 1rem;
  }

  .description {
    margin: 0 0 16px;
    color: var(--muted);
  }

  .architecture-map {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    min-height: 300px;
    border: 1px solid rgba(180, 202, 232, 0.12);
    border-radius: 8px;
    padding: 18px;
    background:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      rgba(2, 6, 12, 0.38);
    background-size: 28px 28px;
    overflow: hidden;
  }

  .architecture-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .architecture-lines path {
    fill: none;
    stroke: rgba(88, 220, 230, 0.26);
    stroke-width: 2;
    stroke-dasharray: 8 12;
  }

  .architecture-zone {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 244px;
    border: 1px solid rgba(180, 202, 232, 0.16);
    border-radius: 8px;
    padding: 16px;
    background: rgba(9, 15, 28, 0.86);
  }

  .architecture-zone h3 {
    margin: 0;
    color: var(--text-strong);
    font-size: 1rem;
    letter-spacing: 0;
  }

  .architecture-zone div {
    display: grid;
    gap: 9px;
    margin-top: 18px;
  }

  .architecture-zone span,
  .architecture-footer span {
    border: 1px solid rgba(180, 202, 232, 0.15);
    border-radius: 8px;
    padding: 9px 10px;
    background: rgba(255, 255, 255, 0.045);
    color: #dce8f7;
    font-size: 0.86rem;
    font-weight: 850;
  }

  .architecture-zone.cyan {
    border-color: rgba(88, 220, 230, 0.32);
  }

  .architecture-zone.green {
    border-color: rgba(134, 239, 172, 0.32);
  }

  .architecture-zone.amber {
    border-color: rgba(247, 200, 106, 0.34);
  }

  .architecture-zone.violet {
    border-color: rgba(196, 181, 253, 0.34);
  }

  .architecture-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  @media (max-width: 960px) {
    .architecture-map {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .architecture-map {
      grid-template-columns: 1fr;
    }
  }
</style>
