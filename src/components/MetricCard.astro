---
type Props = {
  value: string;
  label: string;
};

const { value, label } = Astro.props;
---

<article class="metric panel">
  <strong>{value}</strong>
  <span>{label}</span>
</article>

<style>
  .metric {
    min-height: 112px;
    padding: 20px;
    border-radius: 8px;
  }

  strong {
    display: block;
    color: var(--green);
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
  }

  span {
    display: block;
    margin-top: 10px;
    color: var(--muted);
    font-weight: 800;
  }
</style>

