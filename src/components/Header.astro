---
import { profile } from '@data/profile';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Systems', href: '/systems/' },
  { label: 'Case Studies', href: '/projects/' },
  { label: 'Quant & Forecasting', href: '/quant-forecasting/' },
  { label: 'Data Science Lab', href: '/data-science-lab/' },
  { label: 'Experience', href: '/experience/' },
  { label: 'GitHub', href: profile.github },
  { label: 'LinkedIn', href: profile.linkedin },
];
---

<a class="skip-link" href="#main-content">Skip to content</a>
<header class="site-header">
  <nav class="container nav" aria-label="Primary navigation">
    <a class="brand" href="/" aria-label="Home">
      <span class="brand-mark">SD</span>
      <span>{profile.name}</span>
    </a>
    <div class="nav-links">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>
  </nav>
</header>

<style>
  .skip-link {
    position: absolute;
    left: -999px;
    top: 12px;
    z-index: 30;
    padding: 10px 14px;
    border-radius: 8px;
    background: var(--cyan);
    color: #03101b;
    font-weight: 900;
  }

  .skip-link:focus {
    left: 12px;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid rgba(180, 202, 232, 0.14);
    background: rgba(5, 7, 12, 0.78);
    backdrop-filter: blur(20px);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 72px;
    gap: 18px;
  }

  .brand,
  .nav-links {
    display: flex;
    align-items: center;
  }

  .brand {
    flex: 0 0 auto;
    gap: 12px;
    color: var(--text-strong);
    font-weight: 950;
  }

  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 1px solid rgba(88, 220, 230, 0.42);
    border-radius: 8px;
    color: var(--cyan);
    background: rgba(88, 220, 230, 0.09);
    font-size: 0.82rem;
  }

  .nav-links {
    justify-content: flex-end;
    gap: 4px;
  }

  .nav-links a {
    border-radius: 8px;
    padding: 8px 9px;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 850;
    white-space: nowrap;
  }

  .nav-links a:hover {
    background: rgba(255, 255, 255, 0.055);
    color: var(--text-strong);
  }

  @media (max-width: 980px) {
    .nav {
      align-items: flex-start;
      flex-direction: column;
      padding: 12px 0;
    }

    .nav-links {
      width: 100%;
      justify-content: flex-start;
      flex-wrap: wrap;
    }
  }
</style>
