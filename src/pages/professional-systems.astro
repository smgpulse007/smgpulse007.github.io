---
import Layout from '@components/Layout.astro';
import SectionHeader from '@components/SectionHeader.astro';
import ProfessionalSystemsGrid from '@components/ProfessionalSystemsGrid.astro';
import { professionalSystems } from '@data/professionalSystems';
import { impactMetrics, profile } from '@data/profile';

const heroSystems = professionalSystems.slice(0, 4);
---

<Layout
  title={`Professional Systems | ${profile.name}`}
  description="Sanitized enterprise AI system architecture summaries across claims automation, healthcare quality, private document AI, predictive analytics, FWA, and MLOps."
  canonicalPath="/professional-systems/"
>
  <section class="section professional-hero">
    <div class="container hero-panel">
      <div class="hero-copy">
        <p class="section-kicker">Professional Systems</p>
        <h1>Enterprise AI systems from real delivery, translated into public-safe architecture.</h1>
        <p>
          A sanitized map of professional healthcare, insurance, claims automation, document intelligence,
          predictive modeling, FWA analytics, and MLOps patterns. The emphasis is system shape: intake,
          validation, review, deployment, and measurable operational impact.
        </p>
        <div class="button-row">
          <a class="button" href="#systems-atlas">Explore Atlas</a>
          <a class="button secondary" href="/projects/">Compare Case Studies</a>
          <a class="button secondary" href={`mailto:${profile.email}?subject=Resume%20request%20-%20Shailesh%20Dudala`}>Request Resume</a>
        </div>
      </div>

      <aside class="hero-lanes" aria-label="Professional system lanes">
        <span class="lanes-title">System lanes</span>
        {heroSystems.map((system, index) => (
          <a href="#systems-atlas" style={`--system-accent: ${system.accent}`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{system.domain}</strong>
            <small>{system.metric}</small>
          </a>
        ))}
      </aside>
    </div>
  </section>

  <section class="section compact">
    <div class="container outcome-panel" aria-label="Professional outcomes">
      <div>
        <p class="section-kicker">Selected outcomes</p>
        <h2>Operational results, expressed without PHI, PII, employer-confidential data, or proprietary workflows.</h2>
      </div>
      <div class="outcome-ribbon">
        {impactMetrics.map((metric) => (
          <article>
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </article>
        ))}
        <article>
          <strong>$500K</strong>
          <span>new revenue impact</span>
        </article>
      </div>
    </div>
  </section>

  <section id="systems-atlas" class="section compact systems-section">
    <div class="container">
      <SectionHeader
        kicker="Systems atlas"
        title="Six sanitized enterprise patterns, organized by problem, flow, stack, and outcome."
        copy="Each row shows the public-safe shape of a real delivery pattern: what entered the system, how it was validated, where human review stayed visible, and what operational signal it supported."
      />
      <p class="systems-disclaimer">
        Enterprise systems are described as sanitized architecture patterns. Public examples contain no PHI, PII, employer-confidential data, proprietary claims data, private keys, production credentials, or sensitive datasets.
      </p>
      <ProfessionalSystemsGrid />
    </div>
  </section>
</Layout>

<style>
  .professional-hero {
    padding-bottom: 42px;
  }

  .hero-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.48fr);
    gap: 28px;
    align-items: stretch;
    overflow: hidden;
    border: 1px solid rgba(191, 203, 220, 0.15);
    border-radius: 32px;
    padding: clamp(24px, 4vw, 42px);
    background:
      radial-gradient(circle at 14% 0%, rgba(88, 220, 230, 0.18), transparent 21rem),
      radial-gradient(circle at 94% 96%, rgba(141, 232, 180, 0.15), transparent 20rem),
      linear-gradient(135deg, rgba(255, 255, 255, 0.078), rgba(255, 255, 255, 0.022)),
      rgba(7, 13, 23, 0.94);
    box-shadow: 0 34px 110px rgba(0, 0, 0, 0.38);
  }

  .hero-copy {
    display: grid;
    align-content: center;
    gap: 18px;
  }

  h1 {
    max-width: 1080px;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(2.65rem, 5.7vw, 5.65rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .hero-copy p:not(.section-kicker) {
    max-width: 900px;
    margin: 0;
    color: #c3d1e3;
    font-size: clamp(1.02rem, 1.7vw, 1.24rem);
    line-height: 1.55;
  }

  .hero-lanes {
    display: grid;
    gap: 12px;
    align-content: center;
    min-height: 100%;
    border: 1px solid rgba(191, 203, 220, 0.13);
    border-radius: 26px;
    padding: 18px;
    background:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      rgba(2, 6, 12, 0.4);
    background-size: 30px 30px;
  }

  .lanes-title {
    color: var(--green);
    font-size: 0.74rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-lanes a {
    --system-accent: var(--green);
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 4px 12px;
    align-items: center;
    border: 1px solid color-mix(in srgb, var(--system-accent) 32%, rgba(255, 255, 255, 0.08));
    border-radius: 18px;
    padding: 13px;
    background: color-mix(in srgb, var(--system-accent) 8%, rgba(255, 255, 255, 0.04));
    transition:
      transform var(--duration) ease,
      border-color var(--duration) ease,
      box-shadow var(--duration) ease;
  }

  .hero-lanes a:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--system-accent) 52%, white 10%);
    box-shadow: 0 18px 52px rgba(0, 0, 0, 0.28);
  }

  .hero-lanes a span {
    grid-row: 1 / span 2;
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 1px solid color-mix(in srgb, var(--system-accent) 42%, rgba(255, 255, 255, 0.1));
    border-radius: 999px;
    color: var(--system-accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.74rem;
    font-weight: 950;
  }

  .hero-lanes a strong {
    color: #ffffff;
    line-height: 1.1;
  }

  .hero-lanes a small {
    color: #aebdd0;
    font-size: 0.78rem;
    line-height: 1.25;
  }

  .outcome-panel {
    display: grid;
    gap: 22px;
  }

  .outcome-panel h2 {
    max-width: 1040px;
    margin: 0;
    color: #ffffff;
    font-size: clamp(1.65rem, 3.35vw, 3.4rem);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .outcome-ribbon {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    overflow: hidden;
    border: 1px solid rgba(191, 203, 220, 0.14);
    border-radius: 24px;
    background: rgba(191, 203, 220, 0.1);
  }

  .outcome-ribbon article {
    min-height: 122px;
    padding: 18px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.025)),
      rgba(8, 13, 25, 0.94);
  }

  .outcome-ribbon article + article {
    border-left: 1px solid rgba(191, 203, 220, 0.1);
  }

  .outcome-ribbon strong,
  .outcome-ribbon span {
    display: block;
  }

  .outcome-ribbon strong {
    color: var(--green);
    font-size: clamp(1.58rem, 2.7vw, 2.65rem);
    line-height: 1;
  }

  .outcome-ribbon span {
    margin-top: 10px;
    color: var(--text-strong);
    font-weight: 900;
    line-height: 1.15;
  }

  .systems-section {
    padding-top: 62px;
  }

  .systems-disclaimer {
    margin: -10px 0 22px;
    border: 1px solid rgba(141, 232, 180, 0.18);
    border-radius: 18px;
    padding: 14px 16px;
    background: rgba(141, 232, 180, 0.055);
    color: #dffbea;
    font-size: 0.93rem;
    line-height: 1.45;
  }

  @media (max-width: 1180px) {
    .hero-panel {
      grid-template-columns: 1fr;
    }

    .outcome-ribbon {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .outcome-ribbon article:nth-child(4),
    .outcome-ribbon article:nth-child(7) {
      border-left: 0;
    }
  }

  @media (max-width: 680px) {
    .hero-panel {
      border-radius: 26px;
      padding: 20px;
    }

    h1 {
      font-size: 2.35rem;
      line-height: 1.02;
    }

    .outcome-ribbon {
      grid-template-columns: 1fr;
    }

    .outcome-ribbon article + article {
      border-left: 0;
      border-top: 1px solid rgba(191, 203, 220, 0.1);
    }
  }
</style>
